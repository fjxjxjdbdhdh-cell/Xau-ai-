                "time": t.get("received_at", "")[:16]
            }
            for t in reversed(trades)
        ]
    })


@app.route("/api/dashboard/stats")
def api_dashboard_stats():
    stats = load_daily_stats()
    trades = load_trades()
    labeled = [t for t in trades if t.get("outcome") in ("win", "loss")]
    wins = sum(1 for t in labeled if t["outcome"] == "win")
    wr = round(wins / len(labeled) * 100) if labeled else 0
    return jsonify({
        "pnl_today": round(stats.get("daily_pnl", 0), 2),
        "trades_today": stats.get("trades_today", 0),
        "winrate": wr
    })


@app.route("/telegram/webhook", methods=["POST"])
def telegram_webhook():
    update = request.get_json(silent=True) or {}
    try:
        if update.get("message"):
            handle_telegram(update["message"])
        elif update.get("callback_query"):
            handle_callback(update["callback_query"])
    except:
        pass
    return jsonify({"ok": True})


