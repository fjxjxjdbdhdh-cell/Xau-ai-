def daily_reset():
    today = str(datetime.now(timezone.utc).date())
    stats = load_daily_stats()
    if stats.get("date") != today:
        stats = {"date": today, "trades_today": 0, "daily_pnl": 0.0}
        save_daily_stats(stats)
        print("🔄 Новый день — статистика сброшена")
    return stats


def auto_trading_loop():
    print("🤖 Авто-трейдинг запущен (24/7)")
    while True:
        try:
            stats = daily_reset()

            if stats["trades_today"] >= MAX_TRADES_PER_DAY:
                time.sleep(60)
                continue
            if stats["daily_pnl"] >= DAILY_PROFIT_TARGET:
                print(f"🏆 Дневной профит достигнут: +${stats['daily_pnl']:.2f}")
                time.sleep(60)
                continue
            if stats["daily_pnl"] <= DAILY_LOSS_LIMIT:
                print(f"🛑 Дневной убыток достигнут: ${stats['daily_pnl']:.2f}")
                time.sleep(60)
                continue

            if MT5_OK:
                symbol = "XAUUSD"
                rates = mt5.copy_rates_from_pos(symbol, mt5.TIMEFRAME_M1, 0, 100)
                if rates is not None and len(rates) > 50:
                    import pandas as pd

                    df = pd.DataFrame(rates)
                    price = float(df['close'].iloc[-1])

                    df['ema20'] = df['close'].ewm(span=20).mean()
                    df['atr'] = (df['high'] - df['low']).rolling(14).mean()
                    trend = "UP" if df['close'].iloc[-1] > df['ema20'].iloc[-1] else "DOWN"
                    atr = float(df['atr'].iloc[-1])
                    rsi = 50

                    signal = trend
                    sl = price - atr * 1.5 if signal == "UP" else price + atr * 1.5
                    tp = price + atr * 2.0 if signal == "UP" else price - atr * 2.0

                    trade = process_signal(signal, price, rsi, trend, atr, source="auto")

                    if trade["decision"] == "execute" and trade["confidence"] >= 0.85:
                        result = mt5_open_order(signal, price, sl, tp)
                        if result.get("success"):
                            with _lock:
                                stats["trades_today"] += 1
                                save_daily_stats(stats)
                                tg_send(
                                    f"🚨 *АВТО-СДЕЛКА* #{stats['trades_today']}/{MAX_TRADES_PER_DAY}\n"
                                    f"{signal} @ {price}\nSL: {sl:.2f} | TP: {tp:.2f}"
                                )

            time.sleep(60)

        except Exception as e:
            print(f"⚠️ Ошибка авто-трейдинга: {e}")
            time.sleep(30)


