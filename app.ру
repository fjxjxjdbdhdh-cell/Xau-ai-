def _parse_args(args):
    if len(args) != 4:
        raise ValueError("Формат: ЦЕНА RSI ТРЕНД ATR\nПример: 2625 52 UP 15")
    try:
        return float(args[0]), float(args[1]), args[2].upper(), float(args[3])
    except:
        raise ValueError("ЦЕНА, RSI и ATR должны быть числами")


def handle_telegram(message):
    text = (message.get("text") or "").strip()
    chat_id = message.get("chat", {}).get("id")
    parts = text.split()
    cmd = parts[0].lower() if parts else ""
    args = parts[1:]

    if cmd in ("/start", "/menu"):
        keyboard = {
            "inline_keyboard": [
                [
                    {"text": "🟢 BUY", "callback_data": "tg_buy"},
                    {"text": "🔴 SELL", "callback_data": "tg_sell"}
                ],
                [
                    {"text": "💰 Цена", "callback_data": "tg_price"},
                    {"text": "📊 Статус", "callback_data": "tg_status"}
                ],
                [
                    {"text": "🧪 Симулятор", "callback_data": "tg_sim"},
                    {"text": "🤖 AI", "callback_data": "tg_ask"}
                ]
            ]
        }
        tg_send(welcome_text(), chat_id=chat_id, reply_markup=keyboard)
        return

    if cmd in ("/buy", "/sell"):
        side = "BUY" if cmd == "/buy" else "SELL"
        try:
            price, rsi, trend, atr = _parse_args(args)
        except ValueError as e:
            tg_send(f"⚠️ {e}", chat_id=chat_id)
            return
        process_signal(side, price, rsi, trend, atr, source="telegram")
        return

    if cmd in ("/sim_buy", "/sim_sell"):
        side = "BUY" if cmd == "/sim_buy" else "SELL"
        try:
            price, rsi, trend, atr = _parse_args(args)
        except ValueError as e:
            tg_send(f"⚠️ {e}", chat_id=chat_id)
            return
        sl = round(price - atr * 0.8, 2) if side == "BUY" else round(price + atr * 0.8, 2)
        tp = round(price + atr * 2.5, 2) if side == "BUY" else round(price - atr * 2.5, 2)
        trade, sim = sim_trade(side, price, sl, tp)
        emoji = "✅" if trade["outcome"] == "win" else "❌"
        tg_send(
            f"🧪 {emoji} {side} @ {price}\nP/L: ${trade['pnl']:.2f}\nБаланс: ${sim['balance']:.2f}",
            chat_id=chat_id
        )
        return

    if cmd == "/price":
        tg_send("💰 *XAUUSD* — рынок открыт\nЦена: ~$2625 (данные Finnhub)", chat_id=chat_id)
        return

    if cmd == "/status":
        trades = load_trades()
        labeled = [t for t in trades if t.get("outcome") in ("win", "loss")]
        wins = sum(1 for t in labeled if t["outcome"] == "win")
        wr = (wins / len(labeled) * 100) if labeled else 0
        stats = load_daily_stats()
        tg_send(
            f"📊 *Статус*\n"
            f"Сделок: {len(trades)}\n"
            f"Побед: {wins}\n"
            f"Винрейт: {int(wr)}%\n"
            f"Сегодня: {stats['trades_today']}/{MAX_TRADES_PER_DAY} | P&L: ${stats['daily_pnl']:.2f}",
            chat_id=chat_id
        )
        return

    if cmd == "/portfolio":
        sim = load_simulator()
        tg_send(
            f"💼 *Симулятор*\nБаланс: ${sim['balance']:.2f}\nP&L: ${sim['daily_pnl']:.2f}",
            chat_id=chat_id
        )
        return

    if cmd == "/ask":
        question = " ".join(args).strip()
        if not question:
            tg_send("ℹ️ Используйте: `/ask Ваш вопрос`", chat_id=chat_id)
            return
        answer = deepseek_ask(question)
        tg_send(f"🤖 *AI:*\n{answer}", chat_id=chat_id)
        return


def handle_callback(cb):
    data = cb.get("data", "")
    cb_id = cb.get("id")
    msg = cb.get("message", {})
    chat_id = msg.get("chat", {}).get("id")

    if ":" not in data:
        if data == "tg_buy":
            tg_send("`/buy ЦЕНА RSI ТРЕНД ATR`", chat_id=chat_id)
        elif data == "tg_sell":
            tg_send("`/sell ЦЕНА RSI ТРЕНД ATR`", chat_id=chat_id)
        elif data == "tg_price":
            tg_send("💰 XAUUSD: ~$2625", chat_id=chat_id)
        elif data == "tg_status":
            trades = load_trades()
            wins = sum(1 for t in trades if t.get("outcome") == "win")
            tg_send(f"📊 Сделок: {len(trades)} | Побед: {wins}", chat_id=chat_id)
        elif data == "tg_sim":
            tg_send("`/sim_buy ЦЕНА RSI ТРЕНД ATR`", chat_id=chat_id)
        elif data == "tg_ask":
            tg_send("`/ask Ваш вопрос`", chat_id=chat_id)
        tg_answer(cb_id)
        return

    action, trade_id = data.split(":", 1)
    if action in ("win", "loss"):
        with _lock:
            trades = load_trades()
            target = next((t for t in trades if t.get("id") == trade_id), None)
            if target:
                target["outcome"] = action
                target["labeled_at"] = datetime.now(timezone.utc).isoformat()
                save_trades(trades)
                maybe_run_ga(trades, load_weights())
        tg_answer(cb_id, "✅ Записано" if action == "win" else "❌ Записано")


