from flask import Blueprint, request, jsonify
from flask_jwt_extended import jwt_required, get_jwt_identity
from config import Config
from models import User, PendingDeposit
from extensions import db

bp = Blueprint("payments", __name__, url_prefix="/api/payments")

@bp.route("/details", methods=["GET"])
def details():
    return jsonify({"usdt": Config.USDT_TRC20, "uid": Config.BYBIT_UID, "price": Config.VIP_PRICE_USDT})

@bp.route("/deposit", methods=["POST"])
@jwt_required()
def deposit():
    u = User.query.filter_by(username=get_jwt_identity()).first()
    if not u:
        return jsonify({"error": "Не найден"}), 404
    amt = float((request.get_json() or {}).get("amount", 0))
    if amt < Config.VIP_PRICE_USDT:
        return jsonify({"error": f"Мин {Config.VIP_PRICE_USDT} USDT"}), 400
    pd_row = PendingDeposit(user_id=u.id, expected_amount=amt)
    db.session.add(pd_row)
    db.session.commit()
    return jsonify({"success": True, "deposit_id": pd_row.id}), 201
