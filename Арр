        <div style="font-size:9px;color:#848e9c;margin-top:8px">⚡ Работает на собственной модели UltimateTradingAI v31.0 с нейросетью, A/B тестами, бэктестингом и риск-менеджментом</div>
    </div>
</div>

<div id="accountPanel" class="panel">
    <div style="padding:8px">
        <h3 style="color:var(--gold);margin-bottom:8px">👤 Аккаунт</h3>
        <input type="text" id="mt5Login" placeholder="Логин MT5">
        <input type="password" id="mt5Pass" placeholder="Пароль MT5">
        <input type="text" id="mt5Server" placeholder="Сервер" value="MetaQuotes-Demo">
        <button class="btn" style="background:var(--green)" onclick="connectMT5()">🔗 Подключить MT5</button>
        <button class="btn" style="background:var(--red)" onclick="logout()">🚪 Выйти</button>
        <div id="mt5Status" style="font-size:10px;margin-top:4px;text-align:center"></div>
    </div>
</div>

<div class="bottom-nav">
    <div class="nav-i active" onclick="switchPanel('chart')">📈 График</div>
    <div class="nav-i" onclick="switchPanel('status')">📊 Статус</div>
    <div class="nav-i" onclick="switchPanel('terminal')">💼 Сделки</div>
    <div class="nav-i" onclick="switchPanel('vip')">⭐ Подписки</div>
    <div class="nav-i" onclick="switchPanel('ai')">🤖 AI</div>
    <div class="nav-i" onclick="switchPanel('account')">👤</div>
</div>

<div class="modal" id="authModal">
    <div class="modal-box">
        <div style="color:var(--gold);margin-bottom:8px;font-size:14px;font-weight:700">ВХОД</div>
        <input type="email" id="authEmail" placeholder="Email">
        <input type="password" id="authPass" placeholder="Пароль">
        <div style="display:flex;gap:4px;margin-top:8px">
            <button class="btn" style="background:var(--green)" onclick="login()">Войти</button>
            <button class="btn" style="background:var(--red)" onclick="register()">Регистрация</button>
        </div>
        <button class="btn" style="background:#848e9c" onclick="closeAuth()">Отмена</button>
        <div id="authMsg" style="font-size:10px;margin-top:6px;text-align:center;color:var(--red)"></div>
    </div>
</div>

<script src="https://unpkg.com/lightweight-charts@4.1.1/dist/lightweight-charts.standalone.production.js"></script>
<script>
let user = null;
let currentSym = 'XAUUSD';
let aiActiveAsset = 'XAUUSD';
let chart = null;
let candleSeries = null;

function switchPanel(name) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-i').forEach(n => n.classList.remove('active'));
    document.getElementById(name + 'Panel').classList.add('active');
    let panels = ['chart', 'status', 'terminal', 'vip', 'ai', 'account'];
    let idx = panels.indexOf(name);
    if (idx >= 0) document.querySelectorAll('.nav-i')[idx].classList.add('active');
    if (name === 'chart') { if (chart) { chart.removeSeries(candleSeries); chart = null; candleSeries = null; } initChart(); updateHeatmap(); updateSentiment(); }
    if (name === 'status') { loadAccountStatus(); loadAnalysis(); }
    if (name === 'terminal') loadHistory();
}

function changeSym(sym) {
    currentSym = sym;
    document.querySelectorAll('.sym').forEach(s => s.classList.remove('active'));
    document.getElementById('sym-' + sym).classList.add('active');
    if (sym === aiActiveAsset) document.getElementById('sym-' + sym).classList.add('ai-active');
    document.getElementById('heatmapSymbol').textContent = sym;
    updatePrices(); updateHeatmap(); updateSentiment();
    if (chart) { chart.removeSeries(candleSeries); chart = null; candleSeries = null; initChart(); }
}

function setAIAsset() {
    if (!user) return alert('Войдите в аккаунт');
    let asset = prompt('Актив для ИИ:\\nXAUUSD / EURUSD / GBPUSD', aiActiveAsset);
    if (!asset || !['XAUUSD','EURUSD','GBPUSD'].includes(asset.toUpperCase())) return;
    asset = asset.toUpperCase();
    api('/api/set_active_asset', {method:'POST', body:JSON.stringify({asset})}).then(d => {
        if (d.success) { aiActiveAsset = asset; document.getElementById('assetBtn').textContent = '🎯 ИИ: ' + asset; updateAssetBadges(); }
    });
}

function updateAssetBadges() {
    document.querySelectorAll('.sym').forEach(s => s.classList.remove('ai-active'));
    let el = document.getElementById('sym-' + aiActiveAsset);
    if (el) el.classList.add('ai-active');
}

function showAuth() { document.getElementById('authModal').classList.add('active'); }
function closeAuth() { document.getElementById('authModal').classList.remove('active'); }

function api(url, options = {}) {
    return fetch(url, { headers: {'Content-Type': 'application/json'}, ...options }).then(r => r.json());
}

function login() {
    let e = document.getElementById('authEmail').value;
    let p = document.getElementById('authPass').value;
    api('/api/login', {method:'POST', body:JSON.stringify({email:e, password:p})}).then(d => {
        if (d.error) { document.getElementById('authMsg').textContent = d.error; return; }
        user = d; checkSubscriptionStatus(); updateUI(); closeAuth();
        localStorage.setItem('gm_user', JSON.stringify(d));
    });
}

function register() {
    let e = document.getElementById('authEmail').value;
    let p = document.getElementById('authPass').value;
    api('/api/register', {method:'POST', body:JSON.stringify({email:e, password:p})}).then(d => {
        if (d.error) { document.getElementById('authMsg').textContent = d.error; return; }
        user = d; updateUI(); closeAuth();
        localStorage.setItem('gm_user', JSON.stringify(d));
    });
}

function checkSubscriptionStatus() {
    if (!user) return;
    api('/api/subscription/status?email=' + user.email).then(d => {
        user.tier = d.tier;
        user.ai_level = d.ai_level;
        document.getElementById('vipStatus').textContent = d.tier === 'free' ? '🔒 Нет подписки' : '✅ ' + d.tier.toUpperCase() + ' | ИИ ур. ' + d.ai_level;
        document.getElementById('aiLevelDisplay').innerHTML = d.level_icon + ' UltimateAI ур. ' + d.ai_level + '/10 (' + d.level_name + ')';
        document.getElementById('aiLearningFill').style.width = (d.ai_level * 10) + '%';
        updateUI();
    });
    api('/api/ab_test/status').then(d => {
        if (d) {
            document.getElementById('abBadge').textContent = '🧪 A/B: ' + d.active_version + ' | A: ' + d.version_a_winrate + '% B: ' + d.version_b_winrate + '%';
        }
    });
}

function updateUI() {
    let badge = '<span class="badge badge-free">FREE</span>';
    if (user && user.tier === 'vip') badge = '<span class="badge badge-vip">VIP</span>';
    if (user && user.tier === 'business') badge = '<span class="badge badge-business">БИЗНЕС</span>';
    if (user && user.tier === 'admin') badge = '<span class="badge badge-admin">ADMIN</span>';
    document.getElementById('userInfo').innerHTML = (user ? user.email.split('@')[0] : '🔐 Вход') + ' ' + badge;
    updateAssetBadges();
}

function logout() { user = null; localStorage.removeItem('gm_user'); document.getElementById('userInfo').textContent = '🔐 Вход'; }

function toggleAutoTrade() {
    if (!user) return alert('Войдите');
    if (user.tier === 'free') return alert('❌ Нужна подписка!');
    api('/api/autotrade/toggle', {method:'POST'}).then(d => updateAutoUI(d.enabled));
}

function emergencyStop() {
    if (!confirm('🛑 Закрыть ВСЕ позиции?')) return;
    api('/api/emergency_stop', {method:'POST'}).then(d => { if (d.success) { alert('✅ Закрыто: ' + d.closed); updateAutoUI(false); } });
}

function updateAutoUI(enabled) {
    let btn = document.getElementById('autoTradeBtn');
    let embtn = document.getElementById('emergencyBtn');
    btn.textContent = enabled ? 'ВКЛ' : 'ВЫКЛ';
    btn.className = enabled ? 'btn btn-on' : 'btn btn-off';
    embtn.style.display = enabled ? 'inline-block' : 'none';
}

function updatePrices() {
    api('/api/price?symbol=' + currentSym).then(d => {
        if (d.bid) {
            document.getElementById('chartPrice').textContent = '$' + ((d.bid + d.ask) / 2).toFixed(2);
            document.getElementById('priceChange').textContent = 'Спред: $' + (d.spread || 0).toFixed(2);
        }
    });
}
setInterval(updatePrices, 2000);

function doTrade(signal) {
    if (!user) return alert('Войдите');
    let lot = parseFloat(document.getElementById('lotSelect').value) || 0.02;
    let sl = parseFloat(document.getElementById('slInput').value) || 0;
    let tp = parseFloat(document.getElementById('tpInput').value) || 0;
    if (!sl || !tp) { alert('Введите SL и TP'); return; }
    let price = parseFloat(document.getElementById('chartPrice').textContent.replace('$','')) || 0;
    api('/api/trade', {method:'POST', body:JSON.stringify({signal, symbol: currentSym, price, sl, tp, lot, username: user.email})}).then(d => {
        alert(d.success ? '✅ Сделка открыта!' : '❌ ' + d.error);
    });
}

function paySubscription(tier) {
    if (!user) return alert('Войдите');
    let amount = tier === 'vip' ? 19.99 : 49.99;
    window.open('bybit://app/transfer?uid=495132302&amount=' + amount + '&coin=USDT', '_blank');
    setTimeout(() => {
        let txid = prompt('ID транзакции:');
        if (txid) {
            api('/api/subscription/activate', {method:'POST', body:JSON.stringify({email: user.email, tier, txid})}).then(d => {
                if (d.success) { alert('✅ ' + tier.toUpperCase() + ' до ' + d.expires); checkSubscriptionStatus(); }
                else alert('❌ ' + d.error);
            });
        }
    }, 2000);
}

function initChart() {
    if (chart) return;
    chart = LightweightCharts.createChart(document.getElementById('chart_container'), {
        layout: { background: { color: '#0d1117' }, textColor: '#848e9c' },
        grid: { vertLines: { color: '#1a1a2e' }, horzLines: { color: '#1a1a2e' } },
        crosshair: { mode: 1 },
        rightPriceScale: { borderColor: '#2b3139' },
        timeScale: { borderColor: '#2b3139', timeVisible: true }
    });
    candleSeries = chart.addCandlestickSeries({
        upColor: '#0ecb81', downColor: '#f6465d',
        borderUpColor: '#0ecb81', borderDownColor: '#f6465d',
        wickUpColor: '#0ecb81', wickDownColor: '#f6465d'
    });
    chart.timeScale().fitContent();
    loadChartData();
    setInterval(loadChartData, 5000);
}

function loadChartData() {
    if (!candleSeries) return;
    api('/api/chart_data?symbol=' + currentSym).then(data => { if (data && data.length > 0) candleSeries.setData(data); });
}

function updateHeatmap() {
    api('/api/heatmap?symbol=' + currentSym).then(data => {
        if (!data || data.length === 0) return;
        const container = document.getElementById('heatmap_container');
        const h = 300;
        const prices = data.map(d => d.price);
        const minP = Math.min(...prices) - 10;
        const maxP = Math.max(...prices) + 10;
        const range = maxP - minP || 1;
        let html = '';
        data.forEach(d => {
            const y = ((maxP - d.price) / range) * (h - 40) + 5;
            const alpha = Math.max(0.3, d.intensity || 0.5);
            let bgColor, cls, label;
            if (d.type === 'resistance') { bgColor = `rgba(246,70,93,${alpha})`; cls = 'hm-resistance'; label = `🔴 R | $${d.price}`; }
            else if (d.type === 'support') { bgColor = `rgba(14,203,129,${alpha})`; cls = 'hm-support'; label = `🟢 S | $${d.price}`; }
            else { bgColor = `rgba(240,185,11,0.95)`; cls = 'hm-current'; label = `⚡ $${d.price}`; }
            html += `<div class="heatmap-level ${cls}" style="top:${y}px;background:${bgColor}">${label}</div>`;
        });
        container.innerHTML = html;
    });
}

function updateSentiment() {
    api('/api/social').then(d => {
        if (!d) return;
        let bull = (d.bull_ratio || 0.5) * 100;
        document.getElementById('sentBull').style.width = Math.max(bull, 20) + '%';
        document.getElementById('sentBull').textContent = '🐂 ' + bull.toFixed(0) + '%';
        document.getElementById('sentBear').style.width = Math.max(100 - bull, 20) + '%';
        document.getElementById('sentBear').textContent = '🐻 ' + (100 - bull).toFixed(0) + '%';
    });
}

function loadAccountStatus() {
    api('/api/account').then(d => {
        document.getElementById('accBalance').textContent = '$' + (d.balance || 0).toFixed(2);
        document.getElementById('accEquity').textContent = '$' + (d.equity || 0).toFixed(2);
        document.getElementById('accMargin').textContent = '$' + (d.margin || 0).toFixed(2);
        document.getElementById('accMarginFree').textContent = '$' + (d.margin_free || 0).toFixed(2);
    });
    api('/api/positions').then(d => {
        let html = '';
        if (d.positions && d.positions.length > 0) {
            d.positions.forEach(p => {
                html += `<div class="trade-row"><span class="${p.type==='BUY'?'c-buy':'c-sell'}">${p.symbol} ${p.type}</span><span>$${p.price_open.toFixed(2)} → $${p.price_current.toFixed(2)}</span><span style="color:${p.profit>=0?'var(--green)':'var(--red)'}">${p.profit>=0?'+':''}$${p.profit.toFixed(2)}</span></div>`;
            });
        } else { html = '<div class="trade-row">Нет позиций</div>'; }
        document.getElementById('statusPositions').innerHTML = html;
    });
}

function loadAnalysis() {
    api('/api/self_analysis').then(d => {
        let html = '';
        if (d.mistakes && d.mistakes.length > 0) {
            html += '<b>Ошибки:</b><br>';
            d.mistakes.slice(-3).reverse().forEach(m => { html += `• ${m.description?.substring(0, 80) || m.type}<br>`; });
        }
        document.getElementById('analysisBox').innerHTML = html || 'Нет данных';
    });
}

function aiChat() {
    let msg = document.getElementById('chatInput').value;
    if (!msg) return;
    document.getElementById('chatBox').innerHTML += '<div style="color:var(--gold)">Вы: ' + msg + '</div>';
    document.getElementById('chatInput').value = '';
    api('/api/chat', {method:'POST', body:JSON.stringify({message: msg})}).then(d => {
        document.getElementById('chatBox').innerHTML += '<div style="color:#848e9c">UltimateAI: ' + (d.reply || '—') + '</div>';
    });
}

function connectMT5() {
    let login = document.getElementById('mt5Login').value;
    let password = document.getElementById('mt5Pass').value;
    let server = document.getElementById('mt5Server').value;
    if (!login || !password) { alert('Введите данные'); return; }
    api('/api/mt5', {method:'POST', body:JSON.stringify({login, password, server})}).then(d => {
        document.getElementById('mt5Status').textContent = d.message || d.error || 'Ошибка';
        document.getElementById('mt5Status').style.color = d.message ? 'var(--green)' : 'var(--red)';
    });
}

function loadHistory() {
    api('/api/trades').then(d => {
        let html = '';
        if (d.trades && d.trades.length > 0) {
            d.trades.slice(0, 30).forEach(t => {
                let icon = t.auto ? '🤖' : '👆';
                let cls = t.signal === 'BUY' ? 'c-buy' : 'c-sell';
                let resultHtml = '';
                if (t.outcome === 'win') resultHtml = '<span style="color:var(--green)">+$' + (t.profit || 0).toFixed(1) + '</span>';
                else if (t.outcome === 'loss') resultHtml = '<span style="color:var(--red)">-$' + Math.abs(t.profit || 0).toFixed(1) + '</span>';
                else if (t.outcome === 'timeout') resultHtml = '<span style="color:var(--gold)">⏰</span>';
                else resultHtml = '<span style="color:#848e9c">Открыта</span>';
