<div id="vipPanel" class="panel">
    <div class="sub-card" style="background:linear-gradient(135deg,#1a1a00,#332200);border:1px solid var(--gold)">
        <h3 style="color:var(--gold)">💎 VIP — $19.99 USDT</h3>
        <ul style="font-size:12px;margin:8px 0;list-style:none">
            <li>✅ Авто-трейдинг</li><li>🎯 Уровень ИИ: 5</li><li>📅 30 дней</li>
