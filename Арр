# Функция открытия ордера с проверкой проскальзывания
# ═══════════════════════════════════════════════════════════════════════════

def open_order_with_slippage_check(symbol, signal, price, sl, tp, lot=0.02, max_slippage_percent=0.5):
    if not init_mt5():
        return {"error": "MT5 offline"}
    
    tick = mt5.symbol_info_tick(symbol)
    if not tick:
        return {"error": "Не удалось получить цену"}
    
    actual_price = tick.ask if signal == "BUY" else tick.bid
    slippage_percent = abs(actual_price - price) / price * 100
    
    if slippage_percent > max_slippage_percent:
        logger.warning(f"⚠️ Проскальзывание {slippage_percent:.3f}% > {max_slippage_percent}%, отмена сделки")
        return {"error": f"Проскальзывание {slippage_percent:.2f}% превышает лимит"}
    
    if signal == "BUY":
        adjusted_sl = min(sl, actual_price - (price - sl) * 0.9) if sl > 0 else 0
        adjusted_tp = max(tp, actual_price + (tp - price) * 0.9) if tp > 0 else 0
    else:
        adjusted_sl = max(sl, actual_price + (price - sl) * 0.9) if sl > 0 else 0
        adjusted_tp = min(tp, actual_price - (price - tp) * 0.9) if tp > 0 else 0
    
    return open_order(symbol, signal, actual_price, adjusted_sl, adjusted_tp, lot)

