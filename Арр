# Валидация весов (защита от переобучения)
# ═══════════════════════════════════════════════════════════════════════════

def validate_weights(weights, validation_trades):
    if len(validation_trades) < 3:
        return 0.5
    
    correct = 0
    total = 0
    for trade in validation_trades:
        if trade.get("outcome") not in ("win", "loss"):
            continue
        features = trade.get("features")
        if not features:
            continue
        prediction = compute_confidence(features, weights) >= 0.70
        actual = trade["outcome"] == "win"
        if prediction == actual:
            correct += 1
        total += 1
    
    return correct / total if total > 0 else 0.5

def evolve_weights_with_validation(current_weights, trades):
    if len(trades) < 10:
        return current_weights, None
    
    split_idx = int(len(trades) * 0.7)
    train_trades = trades[:split_idx]
    val_trades = trades[split_idx:]
    
    new_weights, fitness = evolve_weights(current_weights, train_trades)
    
    if new_weights != current_weights:
        old_val_score = validate_weights(current_weights, val_trades)
        new_val_score = validate_weights(new_weights, val_trades)
        
        if new_val_score < old_val_score - 0.05:
            logger.warning(f"⚠️ Переобучение! Откат весов (старые: {old_val_score:.3f}, новые: {new_val_score:.3f})")
            return current_weights, None
        
        logger.info(f"✅ Валидация пройдена: старая {old_val_score:.3f} → новая {new_val_score:.3f}")
    
    return new_weights, fitness

