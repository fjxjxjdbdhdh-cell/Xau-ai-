def ask_ai(question):
    """Чат с AI — использует нашу модель UltimateTradingAI"""
    try:
        trades = load_trades()
        labeled = [t for t in trades if t.get("outcome") in ("win", "loss")]
        wins = sum(1 for t in labeled if t["outcome"] == "win")
        winrate = round(wins / len(labeled) * 100) if labeled else 0

        ai_learning = load_ai_learning()
        neural = load_neural_memory()
        dna = load_strategy_dna()
        effective_level = get_effective_ai_level()
        ai_stats = ULTIMATE_AI.get_stats()
        
        real_data = get_real_market_data(get_active_asset())
        real_context = ""
        if real_data:
            real_context = (
                f"📊 Реальные данные: {real_data['symbol']} = ${real_data['current_price']:.2f}, "
                f"RSI={real_data['rsi']}, ATR=${real_data['atr']}, "
                f"Тренд: {real_data['trend_h1']}, Спред=${real_data['spread']}. "
            )

        # Формируем ответ на основе данных и статистики модели
        if "прибыль" in question.lower() or "профит" in question.lower() or "pnl" in question.lower():
            stats = load_daily_stats()
            backtest = BACKTESTER.get_results()
            backtest_str = f"\n📊 Бэктест: {backtest.get('total_trades', 0)} сделок, Sharpe {backtest.get('sharpe_ratio', 0)}" if backtest and backtest.get("total_trades", 0) > 0 else ""
            return f"📈 *Дневная прибыль:* ${stats.get('auto_pnl', 0):.2f}\n🤖 Всего сделок сегодня: {stats.get('auto_trades', 0)}\n🎯 Текущий винрейт модели: {ai_stats['accuracy']}%{backtest_str}\n{real_context}"
        
        elif "риск" in question.lower() or "опасно" in question.lower():
            return f"⚠️ *Оценка риска:*\n- Текущий спред: ${real_data.get('spread', '?')}\n- ATR (волатильность): ${real_data.get('atr', '?')}\n- Рекомендация: {'СПОКОЙНАЯ' if real_data.get('atr', 30) < 20 else 'ПОВЫШЕННАЯ ВОЛАТИЛЬНОСТЬ'}\n{real_context}"
        
        elif "уровень" in question.lower() or "ии" in question.lower():
            level_data = AI_LEVELS.get(effective_level, AI_LEVELS[1])
            return f"🧠 *Уровень ИИ:* {effective_level}/10 - {level_data['name']} {level_data['icon']}\n🎁 Бонус: {level_data['bonus']}\n📊 Точность UltimateAI: {ai_stats['accuracy']}%\n📚 Правил изучено: {ai_stats['rules_count']}\n🧪 A/B версия: {AI_TESTER.active_version}"
        
        elif "почему" in question.lower() or "объясни" in question.lower():
            if ULTIMATE_AI.decision_history:
                last = ULTIMATE_AI.decision_history[-1]
                return f"🤔 *Объяснение последнего решения:*\nДействие: {last['action']}\nУверенность: {last['confidence']*100:.0f}%\nВремя: {last['time']}\n{real_context}"
            return f"Пока нет истории решений. {real_context}"
        
        elif "нейросеть" in question.lower() or "neural" in question.lower():
            if ULTIMATE_AI.neural_net:
                return f"🧠 *Нейросеть v31.0:*\n- Итераций обучения: {ULTIMATE_AI.neural_net.training_iterations}\n- Архитектура: {ULTIMATE_AI.neural_net.input_size}→{ULTIMATE_AI.neural_net.hidden_size}→{ULTIMATE_AI.neural_net.output_size}\n- Dropout: {ULTIMATE_AI.neural_net.dropout_rate}\n- Последняя ошибка: {ULTIMATE_AI.neural_net.loss_history[-1] if ULTIMATE_AI.neural_net.loss_history else 'нет данных'}\n- Лучшая val loss: {ULTIMATE_AI.neural_net.best_val_loss:.4f if ULTIMATE_AI.neural_net.best_val_loss != float('inf') else 'N/A'}"
            return "Нейросеть не доступна (установите numpy)"
        
        elif "бэктест" in question.lower() or "backtest" in question.lower():
            backtest = BACKTESTER.get_results()
            if backtest and backtest.get("total_trades", 0) > 0:
                return f"📊 *Результаты бэктеста:*\n- Всего сделок: {backtest.get('total_trades', 0)}\n- Винрейт: {backtest.get('winrate', 0)}%\n- Общий P&L: ${backtest.get('total_pnl', 0):.2f}\n- Макс. просадка: {backtest.get('max_drawdown', 0)}%\n- Sharpe Ratio: {backtest.get('sharpe_ratio', 0)}\n- Итоговый баланс: ${backtest.get('final_balance', 0):.2f}"
            return "Нет данных бэктеста. Накопите больше сделок."
        
        elif "дрейф" in question.lower() or "drift" in question.lower():
            drift_status = DRIFT_MONITOR.check_drift([])
            if drift_status.get("psi_values"):
                psi_str = ", ".join([f"{k}: {v}" for k, v in drift_status["psi_values"].items()])
                return f"📊 *Мониторинг дрейфа модели:*\n{drift_status.get('message')}\nPSI значения: {psi_str}"
            return "Недостаточно данных для оценки дрейфа модели."
        
        elif "обучение" in question.lower() or "learn" in question.lower():
            return f"🧠 *Статус самообучения v31.0:*\n- Всего решений: {ai_stats['total_decisions']}\n- Точность: {ai_stats['accuracy']}%\n- Циклов обучения: {ai_learning.get('total_learning_cycles', 0)}\n- Нейро-связей: {neural.get('total_connections', 0)}\n- ДНК поколение: {dna.get('generation', 1)}\n- Нейросеть обучена: {ULTIMATE_AI.neural_net.training_iterations if ULTIMATE_AI.neural_net else 0} итераций\n- Память: {ai_stats['memory_size']}/{ai_stats['max_memory_size']}"
        
        else:
            return (f"🤖 *UltimateAI v31.0 (с нейросетью + бэктест + риск-менеджмент)*\n{real_context}\n"
                   f"📊 Статистика: {len(trades)} сделок, винрейт {winrate}%, уровень ИИ {effective_level}/10.\n"
                   f"🧪 A/B тест: версия {AI_TESTER.active_version} активна\n"
                   f"💾 Память AI: {ai_stats['memory_size']}/{ai_stats['max_memory_size']}\n"
                   f"Задайте конкретный вопрос (прибыль, риск, уровень, объясни, обучение, нейросеть, бэктест, дрейф).")
    
    except Exception as e:
        return f"Ошибка: {str(e)[:100]}"

