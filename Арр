def ai_predator_analysis(symbol, df, current_price):
    """Режим Хищник — агрессивная торговля (без DeepSeek API)"""
    try:
        rsi = float(df['rsi'].iloc[-1]) if 'rsi' in df else 50
        atr = float(df['atr'].iloc[-1]) if 'atr' in df else 10
        ema20 = float(df['ema20'].iloc[-1]) if 'ema20' in df else current_price
        ema50 = float(df['close'].ewm(span=50, adjust=False).mean().iloc[-1]) if len(df) >= 50 else ema20
        
        trend = "UP" if current_price > ema20 and ema20 > ema50 else "DOWN" if current_price < ema20 and ema20 < ema50 else "SIDEWAYS"
        
        # Агрессивная логика
        if trend == "UP" and rsi < 60:
            sl = round(current_price - atr * 1.2, 2)
            tp = round(current_price + atr * 3.0, 2)
            return {"action": "BUY", "reason": f"Агрессивный вход: тренд {trend}, RSI {rsi:.0f}", "sl": sl, "tp": tp}
        elif trend == "DOWN" and rsi > 40:
            sl = round(current_price + atr * 1.2, 2)
            tp = round(current_price - atr * 3.0, 2)
            return {"action": "SELL", "reason": f"Агрессивный вход: тренд {trend}, RSI {rsi:.0f}", "sl": sl, "tp": tp}
        
        return {"action": "HOLD", "reason": "Условия для агрессивного входа не выполнены", "sl": 0, "tp": 0}
    except Exception as e:
        logger.error(f"Predator analysis error: {e}")
        return None

