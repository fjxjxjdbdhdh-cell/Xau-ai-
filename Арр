    """Запуск бэктеста"""
    symbol = request.args.get("symbol", "XAUUSD")
    periods = int(request.args.get("periods", 500))
    
    try:
        historical_data_raw = get_historical_rates(symbol, mt5.TIMEFRAME_H1, periods)
        if historical_data_raw is None or len(historical_data_raw) < 100:
            return jsonify({"error": "Недостаточно исторических данных"})
        
        hist_list = []
        for _, row in historical_data_raw.iterrows():
            hist_list.append({
                "open": float(row['open']),
                "high": float(row['high']),
                "low": float(row['low']),
                "close": float(row['close']),
                "time": int(row['time'].timestamp()) if hasattr(row['time'], 'timestamp') else row['time']
            })
        
        result = BACKTESTER.run_backtest(
            lambda df, price, sym: ai_market_analysis_safe(price, df, "", "Нет позиций", sym, "HOLD"),
            hist_list,
            symbol
        )
        
        return jsonify(result)
    except Exception as e:
        return jsonify({"error": str(e)})

