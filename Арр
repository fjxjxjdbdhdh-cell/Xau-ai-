# Регуляризация нейро-памяти
# ═══════════════════════════════════════════════════════════════════════════

MAX_NEURAL_CONNECTIONS = 2000
NEURAL_DECAY_DAYS = 30

def regularize_neural_memory():
    neural = load_neural_memory()
    now = datetime.now(MSK)
    to_remove = []
    
    for key, conn in neural["connections"].items():
        last_seen = conn.get("last_seen", "")
        if last_seen:
            try:
                last_date = datetime.strptime(last_seen, "%d.%m.%Y %H:%M")
                days_old = (now - last_date).days
                if days_old > NEURAL_DECAY_DAYS:
                    to_remove.append(key)
                    continue
            except:
                pass
        
        total = conn["wins"] + conn["losses"]
        if total < 5 and conn.get("strength", 0.5) < 0.4:
            to_remove.append(key)
    
    for key in to_remove:
        del neural["connections"][key]
    
    if len(neural["connections"]) > MAX_NEURAL_CONNECTIONS:
        sorted_conn = sorted(
            neural["connections"].items(),
            key=lambda x: (x[1]["wins"] + x[1]["losses"], x[1]["strength"]),
            reverse=True
        )
        neural["connections"] = dict(sorted_conn[:MAX_NEURAL_CONNECTIONS])
    
    neural["total_connections"] = len(neural["connections"])
    neural["last_regularized"] = datetime.now(MSK).strftime("%d.%m.%Y %H:%M")
    save_neural_memory(neural)
    logger.info(f"🧹 Нейро-память регуляризована: {neural['total_connections']} связей, удалено {len(to_remove)}")

