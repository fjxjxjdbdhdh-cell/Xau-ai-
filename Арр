    def _load_successful_patterns_from_memory(self):
        """Загружает успешные паттерны из нейро-памяти"""
        try:
            neural = load_neural_memory()
            strongest = neural.get("strongest_patterns", [])
            for pattern in strongest[:20]:
                self.causal_memory[pattern[:100]] = {
                    "success_rate": 0.7,
                    "count": 1,
                    "last_seen": datetime.now(MSK).strftime("%d.%m.%Y")
                }
            logger.info(f"🧠 Загружено {len(strongest)} паттернов из нейро-памяти")
        except:
            pass
    
    def _get_neural_features(self, features, market_data):
        """ДОБАВЛЕНО: Подготавливает признаки для нейросети"""
        # Нормализуем признаки для нейросети
        rsi_norm = features.get("rsi", 50) / 100.0
        atr_norm = min(1.0, features.get("atr", 10) / 50.0)
        trend_norm = features.get("trend_numeric", 0.5)
        volatility = features.get("volatility", 0.01)
        spread_norm = min(1.0, features.get("spread", 0.5) / 2.0)
        
        return [rsi_norm, atr_norm, trend_norm, volatility, spread_norm]
    
    def decide(self, market_data, features, open_positions_info):
        """
        Главный метод принятия решений с объяснением
        ДОБАВЛЕНО: Использование нейросети
        """
        self.total_decisions += 1
        current_price = market_data.get("current_price", 0)
        rsi = features.get("rsi", 50)
        atr = features.get("atr", 10)
        trend = features.get("trend_numeric", 0.5)
        
        # 1. Проверяем открытые позиции
        if open_positions_info and open_positions_info != "Нет позиций" and len(open_positions_info) > 10:
            close_decision = self._analyze_open_position(market_data, features)
            if close_decision["should_close"]:
                self.decision_history.append({"action": "CLOSE", "time": datetime.now(MSK).strftime("%H:%M:%S")})
                return close_decision
        
        # 2. Поиск похожих ситуаций в памяти
        similar = self._find_similar_situations(features)
        
        # 3. Логический вывод по правилам (с использованием индекса)
        rule_result = self._reason_with_rules_indexed(features, market_data)
        
        # 4. Технический анализ (быстрый)
        technical_action, technical_confidence = self._technical_analysis(rsi, trend, atr, current_price)
        
        # ДОБАВЛЕНО: 5. Нейросеть (глубокое обучение)
        neural_action = "HOLD"
        neural_confidence = 0.5
        if self.neural_net:
            neural_features = self._get_neural_features(features, market_data)
            neural_action, neural_confidence = self.neural_net.predict_action(neural_features)
        
        # 6. Комбинируем решения (голосование с учётом нейросети)
        final_action, final_confidence = self._vote_with_neural(
            rule_result, technical_action, technical_confidence, 
            neural_action, neural_confidence, similar
        )
        
        # 7. Генерируем объяснение
        explanation = self._generate_explanation(final_action, features, rule_result, similar, neural_action)
        
        # 8. Рассчитываем SL и TP на основе ATR
        sl, tp = self._calculate_sl_tp(final_action, current_price, atr)
        
