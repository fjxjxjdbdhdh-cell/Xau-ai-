        <ul style="font-size:12px;margin:8px 0;list-style:none">
            <li>✅ ВСЁ из VIP</li><li>🔥 Уровень ИИ: 10</li><li>🦅 Режим Хищника</li><li>📅 30 дней</li>
        </ul>
        <button class="btn" style="background:var(--purple);color:#fff;width:100%" onclick="paySubscription('business')">🏢 БИЗНЕС $49.99</button>
    </div>
    <div id="vipStatus" style="font-size:10px;color:var(--gold);text-align:center;margin-top:4px"></div>
</div>

<div id="aiPanel" class="panel">
    <div style="padding:8px">
        <div style="color:var(--gold);font-size:12px;margin-bottom:6px">🤖 Ultimate AI — Наша модель + Нейросеть + Бэктест</div>
        <div id="chatBox" style="height:250px;overflow-y:auto;background:#181a20;border-radius:6px;padding:8px;margin:6px 0;font-size:12px">Спросите о рынке... (Нейросеть + Risk Management активны!)</div>
        <div style="display:flex;gap:4px">
