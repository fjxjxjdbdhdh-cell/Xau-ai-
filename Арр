class ModelDriftMonitor:
    """
    Мониторинг дрейфа модели - отслеживает, не устарела ли модель
    """
    
    def __init__(self):
        self.baseline_distribution = {}
        self.current_distribution = {}
        self.drift_history = []
        self.psi_threshold = 0.25  # PSI > 0.25 означает значительный дрейф
    
    def update_baseline(self, features_list):
        """Устанавливает базовое распределение признаков"""
        if not features_list:
            return
        
        for feature_name in features_list[0].keys():
            values = [f.get(feature_name, 0) for f in features_list]
            if isinstance(values[0], (int, float)):
                # Для числовых признаков - гистограмма
                hist, bins = np.histogram(values, bins=10) if NUMPY_AVAILABLE else ([], [])
                self.baseline_distribution[feature_name] = {
                    "hist": hist.tolist() if NUMPY_AVAILABLE else [],
                    "bins": bins.tolist() if NUMPY_AVAILABLE else [],
                    "mean": np.mean(values) if NUMPY_AVAILABLE else 0,
                    "std": np.std(values) if NUMPY_AVAILABLE else 0
                }
    
    def calculate_psi(self, baseline, current, bins):
        """Расчёт Population Stability Index"""
        if not baseline or not current or not bins:
            return 0
        
        psi = 0
        total_baseline = sum(baseline)
        total_current = sum(current)
        
        if total_baseline == 0 or total_current == 0:
            return 0
        
        for i in range(len(bins) - 1):
            base_pct = baseline[i] / total_baseline if i < len(baseline) else 0
            curr_pct = current[i] / total_current if i < len(current) else 0
            
            if base_pct > 0 and curr_pct > 0:
                psi += (curr_pct - base_pct) * np.log(curr_pct / base_pct) if NUMPY_AVAILABLE else 0
        
        return min(1.0, psi)
    
