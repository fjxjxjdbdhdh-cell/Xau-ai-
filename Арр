class Backtester:
    """
    Система бэктестирования стратегий на исторических данных
    """
    
    def __init__(self, initial_balance=1000):
        self.initial_balance = initial_balance
        self.results = {}
    
    def run_backtest(self, signal_generator, historical_data, symbol="XAUUSD"):
        """
        Запуск бэктеста на исторических данных
        
        signal_generator: функция, которая принимает данные и возвращает сигнал
        historical_data: список свечей с полями high, low, close, open, time
        """
        if not historical_data or len(historical_data) < 100:
            return {"error": "Недостаточно исторических данных"}
        
        balance = self.initial_balance
        equity_curve = []
        trades = []
        in_position = False
        position_type = None
        entry_price = 0
        stop_loss = 0
        take_profit = 0
        position_size = 0.02
        
        for i, candle in enumerate(historical_data):
            current_price = candle['close']
            
            # Генерируем сигнал
            signal = None
            try:
                if callable(signal_generator):
                    # Создаём df для совместимости
                    df_data = []
                    for j in range(max(0, i-100), i+1):
                        df_data.append(historical_data[j])
                    signal = signal_generator(df_data, current_price, symbol)
            except:
                signal = None
            
            # Управление открытой позицией
            if in_position:
                # Проверяем SL/TP
                if position_type == "BUY":
                    if current_price <= stop_loss:
                        profit = (current_price - entry_price) * position_size * 100
                        balance += profit
                        trades.append({
                            "type": "BUY",
                            "entry": entry_price,
                            "exit": current_price,
                            "profit": profit,
                            "outcome": "loss" if profit < 0 else "win",
                            "time": candle.get('time', i)
                        })
                        in_position = False
                        position_type = None
                    elif current_price >= take_profit:
                        profit = (current_price - entry_price) * position_size * 100
                        balance += profit
                        trades.append({
                            "type": "BUY",
                            "entry": entry_price,
                            "exit": current_price,
                            "profit": profit,
                            "outcome": "win",
                            "time": candle.get('time', i)
                        })
                        in_position = False
                        position_type = None
                
                elif position_type == "SELL":
                    if current_price >= stop_loss:
                        profit = (entry_price - current_price) * position_size * 100
                        balance += profit
                        trades.append({
                            "type": "SELL",
                            "entry": entry_price,
                            "exit": current_price,
                            "profit": profit,
                            "outcome": "loss" if profit < 0 else "win",
                            "time": candle.get('time', i)
                        })
                        in_position = False
                        position_type = None
                    elif current_price <= take_profit:
                        profit = (entry_price - current_price) * position_size * 100
                        balance += profit
                        trades.append({
                            "type": "SELL",
                            "entry": entry_price,
                            "exit": current_price,
                            "profit": profit,
                            "outcome": "win",
                            "time": candle.get('time', i)
                        })
                        in_position = False
                        position_type = None
            
            # Вход в позицию по сигналу
            elif signal and signal.get("action") in ["BUY", "SELL"] and not in_position:
                action = signal["action"]
                atr = signal.get("atr", 10)
                
                entry_price = current_price
                position_type = action
                
                if action == "BUY":
                    stop_loss = entry_price - atr * 1.5
                    take_profit = entry_price + atr * 2.5
                else:
                    stop_loss = entry_price + atr * 1.5
                    take_profit = entry_price - atr * 2.5
                
                in_position = True
                position_size = 0.02
            
            equity_curve.append(balance)
        
        # Закрываем последнюю позицию по последней цене
        if in_position:
            current_price = historical_data[-1]['close']
            if position_type == "BUY":
                profit = (current_price - entry_price) * position_size * 100
            else:
                profit = (entry_price - current_price) * position_size * 100
            balance += profit
            trades.append({
                "type": position_type,
                "entry": entry_price,
                "exit": current_price,
                "profit": profit,
                "outcome": "win" if profit > 0 else "loss",
                "time": "close"
            })
        
        # Расчёт метрик
        wins = [t for t in trades if t.get("outcome") == "win"]
        losses = [t for t in trades if t.get("outcome") == "loss"]
        winrate = len(wins) / len(trades) if trades else 0
        
        total_pnl = sum(t.get("profit", 0) for t in trades)
        avg_win = sum(t.get("profit", 0) for t in wins) / len(wins) if wins else 0
        avg_loss = abs(sum(t.get("profit", 0) for t in losses) / len(losses)) if losses else 0
        
        # Максимальная просадка
        max_equity = self.initial_balance
        max_drawdown = 0
        for eq in equity_curve:
            if eq > max_equity:
                max_equity = eq
            drawdown = (max_equity - eq) / max_equity * 100
            if drawdown > max_drawdown:
                max_drawdown = drawdown
        
        # Sharpe Ratio (упрощённо)
        returns = []
        for j in range(1, len(equity_curve)):
            ret = (equity_curve[j] - equity_curve[j-1]) / equity_curve[j-1] if equity_curve[j-1] > 0 else 0
            returns.append(ret)
        
        if returns:
            sharpe = (np.mean(returns) / (np.std(returns) + 0.0001)) * np.sqrt(252) if NUMPY_AVAILABLE else 0
        else:
            sharpe = 0
        
        self.results = {
            "total_trades": len(trades),
            "winrate": round(winrate * 100, 1),
            "total_pnl": round(total_pnl, 2),
            "avg_win": round(avg_win, 2),
            "avg_loss": round(avg_loss, 2),
            "max_drawdown": round(max_drawdown, 1),
            "sharpe_ratio": round(sharpe, 2),
            "final_balance": round(balance, 2),
            "total_return": round((balance - self.initial_balance) / self.initial_balance * 100, 1),
            "trades": trades[-20:]  # Последние 20 сделок для отображения
        }
        
        return self.results
    
    def get_results(self):
        return self.results

