        .ultimate-badge { background: linear-gradient(135deg, var(--blue), var(--purple)); padding: 2px 8px; border-radius: 12px; font-size: 9px; margin-left: 8px; }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">⚡ GM Ultimate AI v31.0 <span class="ultimate-badge">NEURAL+BACKTEST+RISK</span></div>
