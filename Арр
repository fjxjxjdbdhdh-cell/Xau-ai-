    def _vote_with_neural(self, rule_result, technical_action, technical_confidence, 
                          neural_action, neural_confidence, similar):
        """
        ДОБАВЛЕНО: Голосование с учётом нейросети
        """
        votes = {"BUY": 0, "SELL": 0, "HOLD": 0}
        confidences = {"BUY": [], "SELL": [], "HOLD": []}
        
        # Голос правил
        if rule_result:
            action = rule_result["action"]
            votes[action] += 1
            confidences[action].append(rule_result["confidence"])
        
        # Голос технического анализа
        votes[technical_action] += 1
        confidences[technical_action].append(technical_confidence)
        
        # ДОБАВЛЕНО: Голос нейросети
        votes[neural_action] += 1
        confidences[neural_action].append(neural_confidence)
        
        # Голос похожих ситуаций
        for s in similar[:3]:
            outcome = s.get("outcome", "")
            if outcome == "win":
                if s.get("action") == "BUY":
                    votes["BUY"] += 1
                    confidences["BUY"].append(0.7)
                elif s.get("action") == "SELL":
                    votes["SELL"] += 1
                    confidences["SELL"].append(0.7)
        
        # Находим победителя
        max_votes = max(votes.values())
        winners = [a for a, v in votes.items() if v == max_votes and max_votes > 0]
        
        if not winners:
            return "HOLD", 0.5
        
        final_action = winners[0]
        
        # Средняя уверенность
        if confidences[final_action]:
            final_confidence = sum(confidences[final_action]) / len(confidences[final_action])
        else:
            final_confidence = 0.5
        
        return final_action, min(0.95, final_confidence)
    
