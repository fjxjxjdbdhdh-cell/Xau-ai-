def fetch_social_sentiment(symbol="XAUUSD"):
    sentiment = {
        "bullish": 0,
        "bearish": 0,
        "neutral": 0,
        "total_posts": 0,
        "sources_checked": 0,
        "updated_at": datetime.now(MSK).strftime("%H:%M:%S"),
        "symbol": symbol,
        "details": [],
    }
    
    headers = {
        "User-Agent": USER_AGENT,
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "en-US,en;q=0.9,ru;q=0.8",
    }
    
    sources = SOCIAL_SOURCES
    if symbol != "XAUUSD":
        sources = [s.replace("XAUUSD", symbol).replace("Gold", "Forex").replace("gold", "forex") for s in SOCIAL_SOURCES]
    
    for url in sources[:5]:
        try:
            web_rate_limiter.wait()
            response = requests.get(url, headers=headers, timeout=15)
            if response.status_code != 200:
                continue
            
            text = response.text.lower()
            text = clean_html_tags(text)
            
            bull_count = sum(text.count(term) for term in BULLISH_TERMS[:10])
            bear_count = sum(text.count(term) for term in BEARISH_TERMS[:10])
            
            bias = "bullish" if bull_count > bear_count else "bearish" if bear_count > bull_count else "neutral"
            
            sentiment["bullish"] += bull_count
            sentiment["bearish"] += bear_count
            sentiment["total_posts"] += 1
            sentiment["sources_checked"] += 1
            
            sentiment["details"].append({
                "source": url.split("/")[2][:30],
                "bias": bias,
                "bull_mentions": bull_count,
                "bear_mentions": bear_count,
            })
            
            time.sleep(0.5)
            
        except Exception as e:
            logger.error(f"[Social] Error fetching {url}: {e}")
    
    total = sentiment["bullish"] + sentiment["bearish"] or 1
    bull_ratio = sentiment["bullish"] / total
    
    sentiment["overall"] = "bullish" if bull_ratio >= SENTIMENT_THRESHOLD else "bearish" if bull_ratio <= (1 - SENTIMENT_THRESHOLD) else "neutral"
    sentiment["bull_ratio"] = round(bull_ratio, 3)
    
    _write(SOCIAL_FILE, sentiment)
    logger.info(f"[Social] Настроение {symbol}: {sentiment['overall']} (бычьих: {bull_ratio:.1%})")
    
    return sentiment

def should_skip_by_sentiment(signal, symbol="XAUUSD"):
    sentiment = _read(SOCIAL_FILE, {"overall": "neutral", "bull_ratio": 0.5})
    
    if sentiment["overall"] == "bullish" and signal == "SELL":
        logger.info(f"[Social] Пропускаю SELL для {symbol} — толпа bullish")
        return True
    
    if sentiment["overall"] == "bearish" and signal == "BUY":
        logger.info(f"[Social] Пропускаю BUY для {symbol} — толпа bearish")
        return True
    
    return False

