        self.rule_index = {
            "oversold": [],
            "overbought": [],
            "trend_up": [],
            "trend_down": []
        }
        
        for rule in self.rules:
            condition = rule.get("condition", "").lower()
            if "oversold" in condition or "перепродан" in condition:
                self.rule_index["oversold"].append(rule)
            if "overbought" in condition or "перекуп" in condition:
                self.rule_index["overbought"].append(rule)
            if "uptrend" in condition or "восходящ" in condition:
                self.rule_index["trend_up"].append(rule)
            if "downtrend" in condition or "нисходящ" in condition:
                self.rule_index["trend_down"].append(rule)
        
        logger.info(f"📚 Построен индекс правил: oversold={len(self.rule_index['oversold'])}, overbought={len(self.rule_index['overbought'])}, trend_up={len(self.rule_index['trend_up'])}, trend_down={len(self.rule_index['trend_down'])}")
    
