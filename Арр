            rates = mt5.copy_rates_from_pos(symbol, tf, 0, 100)
            if rates is None:
                continue
            
            pd = get_pandas()
            df = pd.DataFrame(rates)
            
            for i in range(3, len(df) - 3):
                if df['high'].iloc[i] == max(df['high'].iloc[i-3:i+4]):
                    zones_above.append({
                        "price": round(float(df['high'].iloc[i]), 2),
                        "timeframe": tf_name,
                        "volume": int(df['tick_volume'].iloc[i]) if 'tick_volume' in df else 100,
                    })
                
                if df['low'].iloc[i] == min(df['low'].iloc[i-3:i+4]):
                    zones_below.append({
                        "price": round(float(df['low'].iloc[i]), 2),
                        "timeframe": tf_name,
                        "volume": int(df['tick_volume'].iloc[i]) if 'tick_volume' in df else 100,
                    })
        
        zones_above = _group_zones(zones_above)
        zones_below = _group_zones(zones_below)
        
        zones_above.sort(key=lambda x: x["price"])
        zones_below.sort(key=lambda x: x["price"], reverse=True)
        
        liquidity_data = {
            "above": zones_above[:15],
            "below": zones_below[:15],
            "updated_at": datetime.now(MSK).strftime("%H:%M:%S"),
            "symbol": symbol,
        }
        _write(LIQUIDITY_FILE, liquidity_data)
        
        return liquidity_data
        
    except Exception as e:
        logger.error(f"[Liquidity] Error: {e}")
        return _read(LIQUIDITY_FILE, {"above": [], "below": [], "updated_at": ""})

def _group_zones(zones, threshold=3.0):
    if not zones:
        return []
    
    zones.sort(key=lambda x: x["price"])
    grouped = []
    current_group = [zones[0]]
    
    for i in range(1, len(zones)):
        if zones[i]["price"] - current_group[-1]["price"] <= threshold:
            current_group.append(zones[i])
        else:
            avg_price = round(sum(z["price"] for z in current_group) / len(current_group), 2)
            max_vol = max(z.get("volume", 100) for z in current_group)
            grouped.append({
                "price": avg_price,
                "strength": "high" if len(current_group) >= 2 else "medium",
                "count": len(current_group),
                "volume": max_vol,
            })
            current_group = [zones[i]]
    
    if current_group:
        avg_price = round(sum(z["price"] for z in current_group) / len(current_group), 2)
        max_vol = max(z.get("volume", 100) for z in current_group)
        grouped.append({
            "price": avg_price,
            "strength": "high" if len(current_group) >= 2 else "medium",
            "count": len(current_group),
            "volume": max_vol,
        })
    
    return grouped

def check_liquidity_danger(current_price, signal, symbol="XAUUSD"):
    zones = get_liquidity_zones(symbol)
    
    if signal == "BUY":
        dangerous_zones = [z for z in zones["above"] 
                          if abs(z["price"] - current_price) <= LIQUIDITY_DANGER_ZONE]
    else:
        dangerous_zones = [z for z in zones["below"] 
                          if abs(z["price"] - current_price) <= LIQUIDITY_DANGER_ZONE]
    
    if dangerous_zones:
        zone_prices = ", ".join([f"${z['price']}" for z in dangerous_zones[:3]])
        logger.info(f"[Liquidity] ОПАСНОСТЬ! Близко к зонам: {zone_prices}")
        return True, dangerous_zones
    
    return False, []

def get_pro_heatmap(symbol="XAUUSD"):
    zones = get_liquidity_zones(symbol)
    current = get_price(symbol)
    current_price = ((current["bid"] + current["ask"]) / 2) if current else 2600
    
    levels = []
    
    for zone in zones["above"]:
        intensity = min(1.0, (zone["count"] / 5) * (zone["volume"] / 5000))
        levels.append({
            "price": zone["price"],
            "type": "resistance",
            "intensity": round(intensity, 2),
            "strength": zone.get("strength", "medium"),
            "count": zone.get("count", 1),
            "timeframe": zone.get("timeframe", "H1"),
            "label": f"R{zone.get('count', 1)}",
        })
    
    for zone in zones["below"]:
        intensity = min(1.0, (zone["count"] / 5) * (zone["volume"] / 5000))
        levels.append({
            "price": zone["price"],
            "type": "support",
            "intensity": round(intensity, 2),
            "strength": zone.get("strength", "medium"),
            "count": zone.get("count", 1),
            "timeframe": zone.get("timeframe", "H1"),
            "label": f"S{zone.get('count', 1)}",
        })
    
    levels.append({
        "price": round(current_price, 2),
        "type": "current",
        "intensity": 1.0,
        "strength": "current",
        "count": 0,
        "timeframe": "now",
        "label": "●",
    })
    
    levels.sort(key=lambda x: x["price"], reverse=True)
    
    return levels

