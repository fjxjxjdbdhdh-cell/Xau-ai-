    def _calculate_similarity(self, f1, f2):
        """Косинусное сходство между признаками"""
        if not f1 or not f2:
            return 0
        
        common_keys = set(f1.keys()) & set(f2.keys())
        if not common_keys:
            return 0
        
        f1_numeric = {}
        f2_numeric = {}
        
        for k in common_keys:
            v1 = f1[k]
            v2 = f2[k]
            if isinstance(v1, (int, float)) and isinstance(v2, (int, float)):
                f1_numeric[k] = v1
                f2_numeric[k] = v2
            elif isinstance(v1, str) and isinstance(v2, str):
                f1_numeric[k] = 1.0 if v1 == v2 else 0.0
                f2_numeric[k] = 1.0 if v1 == v2 else 0.0
        
        if not f1_numeric:
            return 0
        
        dot = sum(f1_numeric[k] * f2_numeric[k] for k in f1_numeric)
        norm1 = sum(v**2 for v in f1_numeric.values()) ** 0.5
        norm2 = sum(v**2 for v in f2_numeric.values()) ** 0.5
        
        if norm1 == 0 or norm2 == 0:
            return 0
        return dot / (norm1 * norm2)
    
