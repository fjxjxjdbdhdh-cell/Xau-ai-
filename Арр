def normalize_signal(signal_str):
    mapping = {
        "BUY": 1.0, "LONG": 1.0, "STRONG_BUY": 1.0,
        "SELL": 0.0, "SHORT": 0.0, "STRONG_SELL": 0.0,
        "HOLD": 0.5, "NEUTRAL": 0.5,
    }
    return mapping.get(str(signal_str).strip().upper(), 0.5)

def normalize_trend(trend_str):
    mapping = {
        "UP": 1.0, "BULL": 1.0, "BULLISH": 1.0,
        "DOWN": 0.0, "BEAR": 0.0, "BEARISH": 0.0,
        "FLAT": 0.5, "SIDEWAYS": 0.5,
    }
    return mapping.get(str(trend_str).strip().upper(), 0.5)

def normalize_features(signal, price, rsi, trend, atr):
    sig = normalize_signal(signal)
    try:
        price_score = 1.0 / (1.0 + math.exp(-float(price) / 1000.0))
    except:
        price_score = 0.5
    try:
        rsi_value = max(0, min(100, float(rsi)))
    except:
        rsi_value = 50
    if sig >= 0.5:
        rsi_score = max(0, (50 - rsi_value) / 50)
    else:
        rsi_score = max(0, (rsi_value - 50) / 50)
    rsi_score = max(0, min(1, rsi_score + 0.2))
    tr = normalize_trend(trend)
    if sig >= 0.5:
        trend_score = tr
    else:
        trend_score = 1 - tr
    try:
        atr_value = float(atr)
    except:
        atr_value = 0
    atr_score = max(0, min(1, 1 - (atr_value / 100)))
    return {
        "signal": sig,
        "price": price_score,
        "rsi": rsi_score,
        "trend": trend_score,
        "atr": atr_score,
    }

def compute_confidence(features, weights):
    total = sum(weights.values()) or 1
    confidence = sum(features[k] * weights[k] for k in weights) / total
    return round(max(0, min(1, confidence)), 4)

def fitness(weights, trades):
    scored = 0
    correct = 0
    for trade in trades:
        if trade.get("outcome") not in ("win", "loss"):
            continue
        features = trade.get("features")
        if not features:
            continue
        prediction = compute_confidence(features, weights) >= 0.70
        actual = trade["outcome"] == "win"
        if prediction == actual:
            correct += 1
        scored += 1
    return correct / scored if scored else 0

def random_weights():
    raw = {k: random.random() for k in DEFAULT_WEIGHTS}
    total = sum(raw.values()) or 1
    return {k: v / total for k, v in raw.items()}

def crossover(parent_a, parent_b):
    child = {k: (parent_a[k] + parent_b[k]) / 2 for k in parent_a}
    total = sum(child.values()) or 1
    return {k: v / total for k, v in child.items()}

def mutate(weights):
    mutated = {}
    for k, v in weights.items():
        if random.random() < GA_MUTATION_RATE:
            mutated[k] = max(0.01, v + random.uniform(-0.15, 0.15))
        else:
            mutated[k] = v
    total = sum(mutated.values()) or 1
    return {k: v / total for k, v in mutated.items()}

def evolve_weights(current_weights, trades):
    labeled = [t for t in trades if t.get("outcome") in ("win", "loss") and t.get("features")]
    if len(labeled) < 2:
        return current_weights, None

    population = [current_weights] + [random_weights() for _ in range(GA_POPULATION - 1)]
    best_weights = current_weights
    best_fitness = fitness(current_weights, labeled)

    for generation in range(GA_GENERATIONS):
        scored_population = sorted(
            ((fitness(w, labeled), w) for w in population),
            key=lambda x: x[0],
            reverse=True,
        )

        if scored_population[0][0] > best_fitness:
            best_fitness = scored_population[0][0]
            best_weights = scored_population[0][1]

        elites = [w for _, w in scored_population[:max(2, GA_POPULATION // 4)]]
        new_population = list(elites)

        while len(new_population) < GA_POPULATION:
            parent_a, parent_b = random.sample(elites, 2)
            child = crossover(parent_a, parent_b)
            child = mutate(child)
            new_population.append(child)

        population = new_population

    logger.info(f"[GA] Evolution completed. Best fitness: {best_fitness:.4f}")
    return best_weights, best_fitness

def maybe_run_ga(trades, weights):
    labeled = [t for t in trades if t.get("outcome") in ("win", "loss")]
    if len(labeled) == 0 or len(labeled) % GA_INTERVAL != 0:
        return weights, None

    logger.info(f"[GA] Starting evolution with {len(labeled)} labeled trades...")
    new_weights, fit = evolve_weights_with_validation(weights, trades)

    if new_weights != weights:
        save_weights(new_weights)
        logger.info(f"[GA] Weights updated! New fitness: {fit:.4f}")

        wins = sum(1 for t in labeled if t["outcome"] == "win")
