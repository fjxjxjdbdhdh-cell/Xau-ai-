def ddg_search(query, timeout=8):
    try:
        web_rate_limiter.wait()
        response = requests.get(
            f"https://html.duckduckgo.com/html/?q={quote_plus(query)}",
            headers={"User-Agent": USER_AGENT},
            timeout=timeout,
        )
        if response.status_code != 200:
            return ""

        soup = BeautifulSoup(response.text, "html.parser")
        snippets = []
        for element in soup.select("a.result__snippet, div.result__snippet"):
            text = element.get_text(" ", strip=True)
            if text and len(text) > 30:
                snippets.append(text)

        return " \n ".join(snippets[:15])
    except:
        return ""

def clean_html_tags(text):
    if not text:
        return ""
    clean = re.sub(r'<[^>]+>', ' ', text)
    clean = re.sub(r'\s+', ' ', clean)
    clean = re.sub(r'&[a-z]+;', ' ', clean)
    return clean.strip()

def analyze_text(text):
    text = clean_html_tags(text)
    lower_text = text.lower()

    bullish_hits = sum(lower_text.count(term) for term in BULLISH_TERMS)
    bearish_hits = sum(lower_text.count(term) for term in BEARISH_TERMS)
    risk_hits = sum(lower_text.count(term) for term in RISK_TERMS)
    tactic_mentions = [w for w in TACTIC_KEYWORDS if w in lower_text]

    snippets = []
    for line in text.split("\n"):
        stripped = clean_html_tags(line.strip())
        if stripped and len(stripped) > 30:
            snippets.append(stripped[:200])

    return {
        "bullish_hits": bullish_hits,
        "bearish_hits": bearish_hits,
        "risk_hits": risk_hits,
        "tactic_mentions": tactic_mentions,
        "sample_snippets": snippets[:5],
    }

def is_similar_tactic(tactic1_name, tactic2_name, threshold=0.8):
    shorter = min(tactic1_name, tactic2_name, key=len)
    longer = max(tactic1_name, tactic2_name, key=len)
    
    if len(shorter) == 0:
        return False
    
    words1 = set(shorter.lower().split())
    words2 = set(longer.lower().split())
    
    if len(words1) == 0:
        return False
    
    common = words1.intersection(words2)
    similarity = len(common) / len(words1)
    
    return similarity >= threshold

