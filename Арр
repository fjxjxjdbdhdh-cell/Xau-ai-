    def _load_tactics_as_rules(self):
        """Конвертируем накопленные тактики в логические правила"""
        try:
            tactics = load_tactics()
            for tactic in tactics[-50:]:
                desc = tactic.get("description", "").lower()
                action = "HOLD"
                if "buy" in desc or "long" in desc or "покупк" in desc:
                    action = "BUY"
                elif "sell" in desc or "short" in desc or "продаж" in desc:
                    action = "SELL"
                
                self.rules.append({
                    "name": tactic.get("name", "Тактика"),
                    "description": desc[:200],
                    "action": action,
                    "condition": desc[:100],
                    "confidence": 0.55,
                    "used_count": 0,
                    "success_count": 0,
                    "source": "tactic"
                })
