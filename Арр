<div id="chartPanel" class="panel active">
    <div class="price-header">
        <span id="chartPrice">—</span>
        <span style="font-size:12px;color:#848e9c" id="priceChange">—</span>
    </div>
    <div class="order-bar">
        <select id="lotSelect">
            <option value="0.01">0.01</option>
            <option value="0.02" selected>0.02</option>
            <option value="0.05">0.05</option>
            <option value="0.10">0.10</option>
        </select>
        <input type="number" id="slInput" placeholder="SL" step="0.01" style="width:55px">
        <input type="number" id="tpInput" placeholder="TP" step="0.01" style="width:55px">
        <button style="background:var(--green)" onclick="doTrade('BUY')">BUY</button>
        <button style="background:var(--red)" onclick="doTrade('SELL')">SELL</button>
    </div>
    <div id="chart_container"></div>
    
    <div style="padding:8px;color:var(--gold);font-size:13px;margin-top:8px;font-weight:700">🔥 ТЕПЛОВАЯ КАРТА <span id="heatmapSymbol">XAUUSD</span></div>
    <div id="heatmap_container"><div style="color:#848e9c;text-align:center;padding-top:130px">Загрузка...</div></div>
    
    <div style="display:flex;justify-content:space-between;padding:4px 10px;font-size:9px;color:#848e9c">
        <span>🟢 Поддержка</span><span>🟡 Цена</span><span>🔴 Сопротивление</span>
    </div>
    
    <div style="padding:8px;color:var(--gold);font-size:12px">👥 НАСТРОЕНИЕ РЫНКА</div>
    <div class="sentiment-bar">
        <div id="sentBull" class="sent-bull" style="width:33%">Быки</div>
        <div id="sentBear" class="sent-bear" style="width:33%">Медведи</div>
        <div id="sentNeut" class="sent-neut" style="width:34%"></div>
    </div>
</div>

<div id="statusPanel" class="panel">
    <div class="account-info">
        <div style="font-weight:700;color:var(--gold);margin-bottom:8px">📊 Статус счёта</div>
        <div class="account-row"><span>Баланс</span><span id="accBalance">—</span></div>
        <div class="account-row"><span>Средства</span><span id="accEquity">—</span></div>
        <div class="account-row"><span>Маржа</span><span id="accMargin">—</span></div>
        <div class="account-row"><span>Свободная маржа</span><span id="accMarginFree">—</span></div>
    </div>
    <div style="padding:8px;color:var(--gold);font-size:12px">ПОЗИЦИИ</div>
