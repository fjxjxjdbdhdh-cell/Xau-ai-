    def _prepare_validation_data(self, trades):
        """ДОБАВЛЕНО: Подготовка данных для валидации нейросети (train/val split 80/20)"""
        if len(trades) < 20:
            return
        
        self.train_features = []
        self.train_targets = []
        self.val_features = []
        self.val_targets = []
        
        for trade in trades:
            if trade.get("features") and trade.get("outcome") in ["win", "loss"]:
                # Признаки для нейросети
                features = trade.get("features", {})
                market_data = {"current_price": trade.get("price", 0)}
                neural_features = self._get_neural_features(features, market_data)
                
                # Цель (one-hot)
                signal = trade.get("signal", "HOLD")
                if signal == "BUY":
                    target = [1, 0, 0]
                elif signal == "SELL":
                    target = [0, 1, 0]
                else:
                    target = [0, 0, 1]
                
                # Для успешных сделок вес больше
                weight = 1.5 if trade.get("outcome") == "win" else 0.5
                for _ in range(int(weight * 10)):
                    if len(self.train_features) < 1000:
                        self.train_features.append(neural_features)
                        self.train_targets.append(target)
        
        # Разделение на train/val (80/20)
        if len(self.train_features) > 10:
            split_idx = int(len(self.train_features) * 0.8)
            self.val_features = self.train_features[split_idx:]
            self.val_targets = self.train_targets[split_idx:]
            self.train_features = self.train_features[:split_idx]
            self.train_targets = self.train_targets[:split_idx]
    
    def learn_from_result(self, trade):
        """
        Обучение на результате сделки — улучшает модель
        ДОБАВЛЕНО: Обучение нейросети с валидацией
        """
        self.learning_iterations += 1
        
        outcome = trade.get("outcome", "")
        profit = trade.get("profit", 0)
        
        if outcome == "win":
            self.correct_decisions += 1
            for rule in self.rules:
                if rule.get("used_count", 0) > 0:
                    rule["success_count"] = rule.get("success_count", 0) + 1
        else:
            for rule in self.rules:
                if rule.get("used_count", 0) > 0:
                    rule["confidence"] = max(0.3, rule.get("confidence", 0.5) - 0.02)
        
        # ДОБАВЛЕНО: Обучение нейросети с валидацией и early stopping
        if self.neural_net and trade.get("features"):
            # Преобразуем исход в one-hot encoding для обучения
            signal = trade.get("signal", "HOLD")
            if signal == "BUY":
                target = [1, 0, 0]
            elif signal == "SELL":
                target = [0, 1, 0]
            else:
                target = [0, 0, 1]
            
            # Получаем признаки для нейросети
            features = trade.get("features", {})
            market_data = {"current_price": trade.get("price", 0)}
            neural_features = self._get_neural_features(features, market_data)
            
            # Добавляем в обучающую выборку
            self.train_features.append(neural_features)
            self.train_targets.append(target)
            if len(self.train_features) > 2000:
                self.train_features = self.train_features[-2000:]
                self.train_targets = self.train_targets[-2000:]
            
            # Обучаем нейросеть
            self.neural_net.backward(neural_features, target, learning_rate=0.03)
            
            # Периодическая валидация (каждые 10 итераций)
            if self.learning_iterations % 10 == 0 and len(self.train_features) > 50:
                self._prepare_validation_data(load_trades())
                if self.val_features and self.val_targets:
                    # Используем отложенную выборку для early stopping
                    for i in range(min(20, len(self.val_features))):
                        self.neural_net.validate([self.val_features[i]], [self.val_targets[i]])
        
        # Сохраняем в причинную память (увеличенный лимит)
        condition_key = f"{trade.get('signal', '')}_{trade.get('symbol', '')}_{profit:.1f}"
        self.causal_memory[condition_key] = {
            "outcome": outcome,
            "profit": profit,
            "time": datetime.now(MSK).strftime("%d.%m.%Y %H:%M")
        }
        
        # Ограничиваем память (НОВЫЙ ЛИМИТ: 2000)
        if len(self.causal_memory) > self.MAX_MEMORY_SIZE:
            oldest_keys = list(self.causal_memory.keys())[:200]
            for key in oldest_keys:
                del self.causal_memory[key]
        
        # Сохранение состояния каждые 5 сделок (было 10)
        if self.learning_iterations % 5 == 0:
            self._save_ai_state()
        
        logger.info(f"🧠 Обучение #{self.learning_iterations}: {outcome} (${profit:.2f}), память: {len(self.causal_memory)}/{self.MAX_MEMORY_SIZE}")
        
        winrate = (self.correct_decisions / max(1, self.total_decisions)) * 100
        tg_send_async(f"🧠 *САМООБУЧЕНИЕ*\n📊 Всего решений: {self.total_decisions}\n✅ Точность: {winrate:.1f}%\n💰 Результат: {'+' if profit > 0 else ''}{profit:.2f}$")
    
