                if self.health_issues_count > 3:
                    init_mt5()
                    self.health_issues_count = 0
            else:
                self.health_issues_count = max(0, self.health_issues_count - 1)

    def reset_daily(self):
        today = str(datetime.now(MSK).date())
        if self.stats.get("date") != today:
            self.stats = {"date": today, "auto_trades": 0, "auto_pnl": 0.0, "start_balance": 0.0}
            save_daily_stats(self.stats)
            global EMERGENCY_STOP
            EMERGENCY_STOP = False

