# ДОБАВЛЕНО: A/B Тестировщик стратегий
# ═══════════════════════════════════════════════════════════════════════════

class AITester:
    """
    A/B тестирование двух версий AI
    - AI_A: текущая стабильная версия
    - AI_B: экспериментальная версия
    """
    
    def __init__(self):
        self.ai_a = None  # Будет инициализирован позже
        self.ai_b = None
        self.results = {"A": {"wins": 0, "losses": 0, "total_pnl": 0, "decisions": []},
                        "B": {"wins": 0, "losses": 0, "total_pnl": 0, "decisions": []}}
        self.active_version = "A"  # Какая версия сейчас используется для торговли
        self.test_mode = False  # Если True — обе версии работают параллельно
        self.last_comparison_time = None
        self.comparison_history = []
    
    def initialize(self, ai_instance):
        """Инициализирует обе версии AI на основе переданного экземпляра"""
        import copy
        self.ai_a = ai_instance
        
        # Создаём экспериментальную версию с копией правил
        self.ai_b = UltimateTradingAI()
        # Копируем правила из основной версии
        self.ai_b.rules = copy.deepcopy(ai_instance.rules)
        self.ai_b.causal_memory = copy.deepcopy(ai_instance.causal_memory)
        self.ai_b.total_decisions = ai_instance.total_decisions
        self.ai_b.correct_decisions = ai_instance.correct_decisions
        
        logger.info("🧪 A/B Тестировщик инициализирован. Версия A (стабильная) и B (экспериментальная)")
    
    def compare(self, market_data, features, open_positions_info):
        """
        Сравнивает решения двух версий AI
        Возвращает: решение активной версии и отчёт о сравнении
        """
        if not self.ai_a or not self.ai_b:
            return None, None
        
        # Получаем решения от обеих версий
        decision_a = self.ai_a.decide(market_data, features, open_positions_info)
        decision_b = self.ai_b.decide(market_data, features, open_positions_info)
        
        # Логируем сравнение
        comparison = {
            "time": datetime.now(MSK).strftime("%H:%M:%S"),
            "decision_a": decision_a["action"],
            "confidence_a": decision_a["confidence"],
            "decision_b": decision_b["action"],
            "confidence_b": decision_b["confidence"],
            "agreement": decision_a["action"] == decision_b["action"]
        }
        self.comparison_history.append(comparison)
        if len(self.comparison_history) > 100:
            self.comparison_history = self.comparison_history[-100:]
        
        # Логируем в файл для анализа
        if comparison["agreement"]:
            logger.debug(f"🧪 A/B: Обе версии согласны — {decision_a['action']}")
        else:
            logger.info(f"🧪 A/B: РАСХОЖДЕНИЕ! A={decision_a['action']} (conf:{decision_a['confidence']}) vs B={decision_b['action']} (conf:{decision_b['confidence']})")
        
        # Возвращаем решение активной версии
        if self.active_version == "A":
            return decision_a, comparison
        else:
            return decision_b, comparison
    
    def learn_from_result(self, trade, version_used):
        """
        Обучает соответствующую версию AI на результате сделки
        version_used: "A" или "B"
        """
        if version_used == "A" and self.ai_a:
            self.ai_a.learn_from_result(trade)
            if trade.get("outcome") == "win":
                self.results["A"]["wins"] += 1
                self.results["A"]["total_pnl"] += trade.get("profit", 0)
            else:
                self.results["A"]["losses"] += 1
                self.results["A"]["total_pnl"] += trade.get("profit", 0)
        elif version_used == "B" and self.ai_b:
            self.ai_b.learn_from_result(trade)
            if trade.get("outcome") == "win":
                self.results["B"]["wins"] += 1
                self.results["B"]["total_pnl"] += trade.get("profit", 0)
            else:
                self.results["B"]["losses"] += 1
                self.results["B"]["total_pnl"] += trade.get("profit", 0)
        
        self.results[version_used]["decisions"].append({
            "outcome": trade.get("outcome"),
            "profit": trade.get("profit", 0),
            "time": datetime.now(MSK).strftime("%H:%M")
        })
        
        # Ограничиваем историю
        if len(self.results[version_used]["decisions"]) > 50:
            self.results[version_used]["decisions"] = self.results[version_used]["decisions"][-50:]
    
    def get_winrate(self, version):
        """Возвращает винрейт для указанной версии"""
        data = self.results.get(version, {"wins": 0, "losses": 0})
        total = data["wins"] + data["losses"]
        if total == 0:
            return 0
        return round(data["wins"] / total * 100, 1)
    
    def switch_version(self):
        """
        Переключает активную версию, если экспериментальная показывает лучшие результаты
        Возвращает: True если произошло переключение
        """
        winrate_a = self.get_winrate("A")
        winrate_b = self.get_winrate("B")
        
        # Нужно минимум 10 сделок на каждой версии для сравнения
        total_a = self.results["A"]["wins"] + self.results["A"]["losses"]
        total_b = self.results["B"]["wins"] + self.results["B"]["losses"]
        
        if total_a >= 10 and total_b >= 10:
            if winrate_b > winrate_a + 10:  # Версия B лучше на 10%+
                old_version = self.active_version
                self.active_version = "B"
                logger.info(f"🧪 A/B: ПЕРЕКЛЮЧЕНИЕ на версию B! (B: {winrate_b}% vs A: {winrate_a}%)")
                tg_send_async(f"🧪 *A/B ТЕСТИРОВАНИЕ*\n🔄 Переключение на версию B\n📊 B: {winrate_b}% | A: {winrate_a}%")
                return True
            elif winrate_a > winrate_b + 10 and self.active_version == "B":
                old_version = self.active_version
                self.active_version = "A"
                logger.info(f"🧪 A/B: Возврат на версию A (A: {winrate_a}% vs B: {winrate_b}%)")
                return True
        
        return False
    
    def get_stats(self):
        """Возвращает статистику A/B тестирования"""
        return {
            "active_version": self.active_version,
            "version_a_winrate": self.get_winrate("A"),
            "version_b_winrate": self.get_winrate("B"),
            "version_a_pnl": round(self.results["A"]["total_pnl"], 2),
            "version_b_pnl": round(self.results["B"]["total_pnl"], 2),
            "total_comparisons": len(self.comparison_history),
            "agreement_rate": round(sum(1 for c in self.comparison_history if c["agreement"]) / max(1, len(self.comparison_history)) * 100, 1)
        }

