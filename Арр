# Асинхронная очередь для Telegram (чтобы не блокировать)
# ═══════════════════════════════════════════════════════════════════════════

telegram_queue = queue.Queue()

def telegram_worker():
    """Фоновый поток для отправки Telegram-сообщений без блокировки"""
    while True:
        try:
            msg_data = telegram_queue.get(timeout=1)
            if msg_data is None:
                break
            chat_id = msg_data.get("chat_id", CHAT_IDS[0])
            text = msg_data.get("text", "")
            try:
                requests.post(
                    f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
                    json={"chat_id": chat_id, "text": text, "parse_mode": "Markdown"},
                    timeout=10
                )
            except Exception as e:
                logger.error(f"TG send error (worker): {e}")
            telegram_queue.task_done()
        except queue.Empty:
            time.sleep(0.1)
        except Exception as e:
            logger.error(f"Telegram worker error: {e}")

threading.Thread(target=telegram_worker, daemon=True).start()

def tg_send_async(text, chat_id=None):
    telegram_queue.put({"chat_id": chat_id, "text": text})

def tg_send(text, chat_id=None):
    tg_send_async(text, chat_id)

