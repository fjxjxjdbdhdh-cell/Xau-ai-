def apply_trailing_stop():
    positions = get_positions()
    for pos in positions:
        try:
            current_price = pos['price_current']
            open_price = pos['price_open']
            current_sl = pos['sl']
            
            if pos['type'] == 'BUY':
                profit_dollars = current_price - open_price
                if profit_dollars >= TRAILING_START:
                    new_sl = current_price - MIN_TRAILING_DISTANCE
                    new_sl = round(new_sl, 2)
                    if new_sl > current_sl and new_sl > open_price:
                        modify_sl(pos['ticket'], new_sl)
                        logger.info(f"🔄 Трейлинг BUY {pos['symbol']}: SL ${current_sl} → ${new_sl}")
            
            elif pos['type'] == 'SELL':
                profit_dollars = open_price - current_price
                if profit_dollars >= TRAILING_START:
                    new_sl = current_price + MIN_TRAILING_DISTANCE
                    new_sl = round(new_sl, 2)
                    if new_sl < current_sl and new_sl < open_price:
                        modify_sl(pos['ticket'], new_sl)
                        logger.info(f"🔄 Трейлинг SELL {pos['symbol']}: SL ${current_sl} → ${new_sl}")
        except Exception as e:
            logger.error(f"Trailing stop error: {e}")

def check_trade_timeout(pos):
    trades = load_trades()
    for t in trades:
        if t.get("ticket") == pos['ticket']:
            trade_time_str = t.get("time", "")
            trade_date_str = t.get("date", "")
            if trade_time_str and trade_date_str:
                try:
                    trade_datetime = datetime.strptime(
                        f"{trade_date_str} {trade_time_str}", 
                        "%d.%m.%Y %H:%M:%S"
                    )
                    trade_datetime = trade_datetime.replace(tzinfo=MSK)
                    duration = datetime.now(MSK) - trade_datetime
                    
                    if duration > timedelta(hours=MAX_TRADE_DURATION_HOURS):
                        logger.info(f"⏰ Таймаут сделки {pos['ticket']} ({duration})")
