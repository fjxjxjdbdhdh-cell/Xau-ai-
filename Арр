def derive_rules(insight_records, trade_history):
    if not insight_records:
        return {
            "confidence_threshold": 0.70,
            "preferred_signal": "HOLD",
            "bias_strength": 0,
            "market_bias": "neutral",
            "risk_mode": "normal",
            "atr_caution_above": 50,
        }

    total_bull = sum(r["analysis"]["bullish_hits"] for r in insight_records)
    total_bear = sum(r["analysis"]["bearish_hits"] for r in insight_records)
    total_risk = sum(r["analysis"]["risk_hits"] for r in insight_records)

    if total_bull > total_bear:
        market_bias = "bullish"
    elif total_bear > total_bull:
        market_bias = "bearish"
    else:
        market_bias = "neutral"

    denominator = total_bull + total_bear or 1
    bias_strength = round(abs(total_bull - total_bear) / denominator, 3)

    risk_threshold = max(5, (total_bull + total_bear) / 4)
    if total_risk > risk_threshold:
        risk_mode = "elevated"
    else:
        risk_mode = "normal"

    labeled_trades = [t for t in trade_history if t.get("outcome") in ("win", "loss")]
    wins = sum(1 for t in labeled_trades if t["outcome"] == "win")
    historical_winrate = round(wins / len(labeled_trades), 3) if labeled_trades else None

    return {
        "generated_at": datetime.now(timezone.utc).isoformat() + "Z",
        "market_bias": market_bias,
        "bias_strength": bias_strength,
        "preferred_signal": (
            "BUY" if market_bias == "bullish"
            else "SELL" if market_bias == "bearish"
            else "HOLD"
        ),
        "risk_mode": risk_mode,
        "atr_caution_above": 30 if risk_mode == "elevated" else 50,
        "confidence_threshold": 0.70,
        "historical_winrate": historical_winrate,
    }

def evolve_insights(trade_history):
    try:
        new_records = gather_insights()
        history = (load_insights() + new_records)[-200:]
        save_insights(history)
        update_knowledge_base(new_records)
        rules = derive_rules(history, trade_history)
        save_rules(rules)
        logger.info(f"[Evolve] {len(new_records)} new insights. Market bias: {rules.get('market_bias')}")
        return {"new": len(new_records), "rules": rules}
    except Exception as e:
        logger.error(f"[Evolve] Error: {e}")
        return {"new": 0, "rules": {}}

