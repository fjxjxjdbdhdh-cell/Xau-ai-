        self.reset_daily()
        
        privileges = get_effective_user_privileges(email) if email else get_effective_user_privileges()
        
        if EMERGENCY_STOP:
            return False
        
        if get_account_info().get('balance', 0) < MIN_BALANCE:
            return False
        
        if not is_trading_session():
            return False
        
        if get_spread(symbol) > MAX_SPREAD:
            return False
        
        max_trades = privileges.get("max_trades", MAX_TRADES_PER_DAY)
