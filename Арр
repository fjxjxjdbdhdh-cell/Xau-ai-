            current_price = real_data["current_price"]
            df['ema20'] = df['close'].ewm(span=20, adjust=False).mean()
            df['atr'] = (df['high'] - df['low']).rolling(14).mean()
            
            delta = df['close'].diff()
            gain = delta.where(delta > 0, 0.0).rolling(14).mean()
            loss = (-delta.where(delta < 0, 0.0)).rolling(14).mean()
            df['rsi'] = 100.0 - (100.0 / (1.0 + (gain / loss)))
            
            analysis = ai_market_analysis_safe(current_price, df, load_knowledge().get("summary", ""), "Нет позиций", symbol, "HOLD")
            
            if analysis and analysis.get("action") in ["BUY", "SELL"]:
                features = normalize_features(
                    analysis["action"], current_price,
                    float(df['rsi'].iloc[-1]),
                    "UP" if analysis["action"] == "BUY" else "DOWN",
                    float(df['atr'].iloc[-1]),
                )
                confidence = compute_confidence(features, load_weights())
                
                if confidence > best_confidence:
                    best_confidence = confidence
                    best_asset = symbol
                    best_signal = analysis["action"]
                    best_sl = analysis.get("sl", 0)
                    best_tp = analysis.get("tp", 0)
        
        if best_asset:
            logger.info(f"🎯 Авто-выбор: {best_asset} (уверенность: {best_confidence:.3f})")
        return best_asset, best_signal, best_confidence, best_sl, best_tp

    def manage_open_trades(self):
        positions = get_positions()
        if not positions:
            return

        now = datetime.now()
        if (now - self.trailing_last_run).seconds >= 120:
            self.trailing_last_run = now
            apply_trailing_stop()

        for pos in positions:
            symbol = pos['symbol']
            
            is_timeout, duration, trade_record = check_trade_timeout(pos)
            if is_timeout:
                if close_position(pos['ticket']):
                    with _lock:
                        if trade_record:
                            trade_record["outcome"] = "timeout"
                            trade_record["profit"] = pos['profit']
                            trade_record["symbol"] = symbol
                        self.stats["auto_pnl"] = round(self.stats.get("auto_pnl", 0) + pos['profit'], 2)
                        save_daily_stats(self.stats)
                        trades = load_trades()
                        save_trades(trades)
                        if trade_record:
                            threading.Thread(target=process_trade_analysis, args=(trade_record.copy(),), daemon=True).start()
                    tg_notify_close(pos['type'], pos['profit'], f"Таймаут {MAX_TRADE_DURATION_HOURS}ч", symbol)
                    continue

            pos_info = f"{pos['type']} {symbol} @ {pos['price_open']} → {pos['price_current']} (${pos['profit']})"
            rates = get_historical_rates(symbol, mt5.TIMEFRAME_M5, 50)
            if rates is None:
                continue
            
            df = rates
            df['ema20'] = df['close'].ewm(span=20, adjust=False).mean()
            df['atr'] = (df['high'] - df['low']).rolling(14).mean()
            
            analysis = ai_market_analysis_safe(float(df['close'].iloc[-1]), df, load_knowledge().get("summary", ""), pos_info, symbol, "HOLD")

            if analysis and analysis.get("action") == "CLOSE" and pos['profit'] >= -0.50:
                logger.info(f"🤖 AI: Закрываю {symbol}. Причина: {analysis['reason']}")
                if close_position(pos['ticket']):
                    with _lock:
                        trades = load_trades()
                        closed_trade = None
                        for t in trades:
                            if t.get("ticket") == pos['ticket']:
                                t["outcome"] = "win" if pos['profit'] > 0 else "loss"
                                t["auto_close_reason"] = analysis['reason']
                                t["profit"] = pos['profit']
                                t["symbol"] = symbol
                                closed_trade = t.copy()
                                self.stats["auto_pnl"] = round(self.stats.get("auto_pnl", 0) + pos['profit'], 2)
                                save_daily_stats(self.stats)
                        save_trades(trades)
                        if closed_trade:
                            threading.Thread(target=process_trade_analysis, args=(closed_trade,), daemon=True).start()
                    tg_notify_close(pos['type'], pos['profit'], analysis['reason'], symbol)

    def run(self):
        global AUTO_TRADING_ENABLED, ACTIVE_TRADING_ASSET
        logger.info("╔══════════════════════════════════════════╗")
        logger.info("║  AutoTrader v31.0 — ULTIMATE AI + NEURAL║")
        logger.info("║  ПОЛНАЯ ЗАМЕНА DeepSeek API            ║")
        logger.info("║  Наша собственная модель UltimateAI    ║")
        logger.info("║  Нейросеть + A/B тестирование         ║")
        logger.info("║  Бэктестинг + Risk Management         ║")
        logger.info("╚══════════════════════════════════════════╝")
        
        while True:
            try:
                self.mt5_health_check()
                self.current_asset = get_active_asset()
                ACTIVE_TRADING_ASSET = self.current_asset
                self.update_social_and_liquidity()

                if not AUTO_TRADING_ENABLED or EMERGENCY_STOP:
                    time.sleep(5)
                    continue

                if not init_mt5():
                    time.sleep(30)
                    continue

                positions = get_positions()
                if positions:
                    self.manage_open_trades()
                    time.sleep(60)
                    continue

                symbol = self.current_asset
                
                effective_level = get_effective_ai_level()
                if effective_level >= 7:
                    cross_opp = cross_asset_analysis()
                    if cross_opp and cross_opp.get("best_opportunity"):
                        opp = cross_opp["best_opportunity"]
                        if opp.get("action") in ["BUY", "SELL"]:
                            logger.info(f"🔗 Кросс-активный сигнал: {opp}")
                
                if not self.can_trade(symbol):
                    time.sleep(60)
                    continue

                real_data = get_real_market_data(symbol)
                if not real_data:
                    time.sleep(5)
                    continue
                
                rates = get_historical_rates(symbol, mt5.TIMEFRAME_M5, 100)
                if rates is None:
                    time.sleep(5)
                    continue
                    
                df = rates
                current_price = real_data["current_price"]
                df['ema20'] = df['close'].ewm(span=20, adjust=False).mean()
                df['atr'] = (df['high'] - df['low']).rolling(14).mean()

                delta = df['close'].diff()
                gain = delta.where(delta > 0, 0.0).rolling(14).mean()
                loss = (-delta.where(delta < 0, 0.0)).rolling(14).mean()
                df['rsi'] = 100.0 - (100.0 / (1.0 + (gain / loss)))

                analysis = ai_market_analysis_safe(current_price, df, load_knowledge().get("summary", ""), "Нет позиций", symbol, "HOLD")

                if analysis and analysis.get("action") in ["BUY", "SELL"]:
                    signal = analysis["action"]
                    
                    if check_liquidity_danger(current_price, signal, symbol)[0]:
                        time.sleep(300)
                        continue
                    
                    if should_skip_by_sentiment(signal, symbol):
                        time.sleep(300)
                        continue
                    
                    sl_raw = analysis["sl"]
                    tp = analysis["tp"]
                    
                    sl_distance = abs(current_price - sl_raw)
                    sl = round(current_price - MAX_SL_DISTANCE, 2) if signal == "BUY" and sl_distance > MAX_SL_DISTANCE else round(current_price + MAX_SL_DISTANCE, 2) if signal == "SELL" and sl_distance > MAX_SL_DISTANCE else sl_raw

                    if (signal == "BUY" and (sl >= current_price or tp <= current_price)) or \
                       (signal == "SELL" and (sl <= current_price or tp >= current_price)):
                        time.sleep(300)
                        continue

                    # ДОБАВЛЕНО: Динамический расчёт лота по Kelly Criterion
                    trades = load_trades()
                    wins = [t for t in trades if t.get("outcome") == "win"]
                    losses = [t for t in trades if t.get("outcome") == "loss"]
                    
                    if wins and losses:
                        winrate = len(wins) / (len(wins) + len(losses))
                        avg_win = sum(t.get("profit", 0) for t in wins) / len(wins)
                        avg_loss = abs(sum(t.get("profit", 0) for t in losses) / len(losses))
                        
                        # Текущая просадка
                        daily_stats = load_daily_stats()
                        current_drawdown = 0
                        if daily_stats.get("start_balance", 0) > 0:
                            current_drawdown = max(0, (daily_stats["start_balance"] - get_account_info().get("balance", 0)) / daily_stats["start_balance"] * 100)
                        
                        dynamic_lot = calculate_dynamic_lot(winrate, avg_win, avg_loss, current_drawdown, LOT_SIZE)
                        logger.info(f"📊 Динамический лот: {dynamic_lot:.3f} (winrate: {winrate*100:.1f}%, просадка: {current_drawdown:.1f}%)")
                    else:
                        dynamic_lot = LOT_SIZE

                    spread = real_data.get("spread", get_spread(symbol))
                    logger.info(f"🚀 ВХОД: {signal} {symbol} @ {current_price}, SL:{sl}, TP:{tp}, Спред:${spread}, Лот:{dynamic_lot}")
                    result = open_order_with_slippage_check(symbol, signal, current_price, sl, tp, dynamic_lot)

                    if result.get("success"):
                        with _lock:
                            self.stats["auto_trades"] = self.stats.get("auto_trades", 0) + 1
                            self.last_trade_time = datetime.now(MSK)
                            save_daily_stats(self.stats)

                            trades = load_trades()
                            trade_record = {
                                "ticket": result["ticket"],
                                "signal": signal,
                                "symbol": symbol,
                                "price": current_price,
                                "sl": sl,
                                "tp": tp,
                                "lot": dynamic_lot,
                                "spread": spread,
                                "time": self.last_trade_time.strftime("%H:%M:%S"),
                                "date": self.last_trade_time.strftime("%d.%m.%Y"),
                                "auto": True,
                                "ai_reason": analysis['reason'],
                                "features": normalize_features(signal, current_price, float(df['rsi'].iloc[-1]), "UP" if signal == "BUY" else "DOWN", float(df['atr'].iloc[-1])),
                            }
                            trades.append(trade_record)
                            save_trades(trades)

                        tg_notify_trade(signal, current_price, sl, tp, analysis['reason'], spread, symbol)
                        maybe_run_ga(trades, load_weights())

                time.sleep(300)

            except Exception as e:
                logger.error(f"⚠️ AutoTrader crash: {e}")
                time.sleep(60)

