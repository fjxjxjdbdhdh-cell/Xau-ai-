def update_neural_memory(trade, market_conditions):
    neural = load_neural_memory()
    
    condition_key = f"{market_conditions.get('trend', '')}_{market_conditions.get('rsi_zone', '')}_{market_conditions.get('session', '')}_{trade.get('symbol', 'XAUUSD')}"
    
    if condition_key not in neural["connections"]:
        neural["connections"][condition_key] = {
            "wins": 0,
            "losses": 0,
            "total_profit": 0,
            "strength": 0,
            "last_seen": "",
        }
    
    conn = neural["connections"][condition_key]
    
    if trade.get("outcome") == "win":
        conn["wins"] += 1
        conn["total_profit"] += trade.get("profit", 0)
    else:
        conn["losses"] += 1
        conn["total_profit"] += trade.get("profit", 0)
    
    total = conn["wins"] + conn["losses"]
    if total > 0:
        conn["strength"] = round(conn["wins"] / total, 3)
    
    conn["last_seen"] = datetime.now(MSK).strftime("%d.%m.%Y %H:%M")
    
    neural["total_connections"] = len(neural["connections"])
    
    sorted_connections = sorted(
        neural["connections"].items(),
        key=lambda x: x[1]["strength"] * (x[1]["wins"] + x[1]["losses"]),
        reverse=True
    )
    neural["strongest_patterns"] = [
        f"{key} (сила:{conn['strength']:.1%}, сделок:{conn['wins']+conn['losses']})"
        for key, conn in sorted_connections[:5]
    ]
    
    neural["last_updated"] = datetime.now(MSK).strftime("%d.%m.%Y %H:%M")
    save_neural_memory(neural)

def evolve_strategy_dna(trades):
    dna = load_strategy_dna()
    
    wins = [t for t in trades if t.get("outcome") == "win"]
    losses = [t for t in trades if t.get("outcome") == "loss"]
    
    if len(wins) + len(losses) < 5:
        return dna
    
    winrate = len(wins) / (len(wins) + len(losses)) if (len(wins) + len(losses)) > 0 else 0
    
    if wins:
        avg_win_profit = sum(t.get("profit", 0) for t in wins) / len(wins)
        avg_win_rr = avg_win_profit / abs(wins[0].get("sl", 1) - wins[0].get("price", 1)) if wins else 1
        
        dna["genes"]["entry_threshold"] = round(max(0.55, min(0.85, dna["genes"]["entry_threshold"] + random.uniform(-0.02, 0.05))), 2)
        dna["genes"]["risk_reward_ratio"] = round(max(1.5, min(3.0, avg_win_rr)), 1)
    
    if losses and len(losses) > len(wins):
        dna["genes"]["entry_threshold"] = round(min(0.85, dna["genes"]["entry_threshold"] + 0.02), 2)
        dna["genes"]["time_filter_strength"] = round(min(1.0, dna["genes"]["time_filter_strength"] + 0.1), 1)
    
    dna["generation"] += 1
    dna["mutations"].append({
        "generation": dna["generation"],
        "winrate": round(winrate, 3),
        "genes": dict(dna["genes"]),
        "time": datetime.now(MSK).strftime("%H:%M"),
    })
    dna["fitness_history"].append(round(winrate, 3))
    
    if len(dna["mutations"]) > 20:
        dna["mutations"] = dna["mutations"][-20:]
    if len(dna["fitness_history"]) > 50:
        dna["fitness_history"] = dna["fitness_history"][-50:]
    
    save_strategy_dna(dna)
    logger.info(f"🧬 ДНК стратегии эволюционировала. Поколение: {dna['generation']}, Винрейт: {winrate:.1%}")
    
    return dna

def update_reinforcement_learning(trade, state, action):
    rl = load_reinforcement()
    
    state_key = f"{state.get('symbol', '')}_{state.get('trend', '')}_{state.get('rsi_zone', '')}"
    action_key = f"{state_key}_{action}"
    
    if action_key not in rl["q_table"]:
        rl["q_table"][action_key] = 0.0
    
    reward = trade.get("profit", 0)
    if reward > 0:
        rl["total_rewards"] += reward
        normalized_reward = min(1.0, reward / 10)
    else:
        rl["total_punishments"] += abs(reward)
        normalized_reward = max(-1.0, reward / 10)
    
    old_value = rl["q_table"][action_key]
    rl["q_table"][action_key] = round(
        old_value + rl["learning_rate"] * (normalized_reward - old_value),
        4
    )
    
    save_reinforcement(rl)

