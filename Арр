def softmax(x):
    """Softmax функция для нормализации выходов нейросети"""
    exp_x = np.exp(x - np.max(x))
    return exp_x / np.sum(exp_x)

class SimpleNeuralNet:
    """
    Простая нейросеть для глубокого обучения (без TensorFlow)
    - 5 входных признаков
    - 10 нейронов в скрытом слое
    - 3 выхода (BUY, SELL, HOLD)
    - ДОБАВЛЕНО: Dropout для защиты от переобучения
    - ДОБАВЛЕНО: Batch normalization (упрощённая)
    - ДОБАВЛЕНО: Early stopping
    """
    
    def __init__(self, input_size=5, hidden_size=10, output_size=3, dropout_rate=0.2):
        self.input_size = input_size
        self.hidden_size = hidden_size
        self.output_size = output_size
        self.dropout_rate = dropout_rate
        
        if NUMPY_AVAILABLE:
            # Инициализация весов методом Xavier/Glorot
            self.weights_input_hidden = np.random.randn(input_size, hidden_size) * np.sqrt(2.0 / input_size)
            self.weights_hidden_output = np.random.randn(hidden_size, output_size) * np.sqrt(2.0 / hidden_size)
            self.bias_hidden = np.zeros((1, hidden_size))
            self.bias_output = np.zeros((1, output_size))
            
            # ДОБАВЛЕНО: Для batch normalization
            self.bn_gamma = np.ones((1, hidden_size))
            self.bn_beta = np.zeros((1, hidden_size))
            self.bn_running_mean = np.zeros((1, hidden_size))
            self.bn_running_var = np.ones((1, hidden_size))
        else:
            # Fallback без numpy
            self.weights_input_hidden = [[random.uniform(-0.5, 0.5) for _ in range(hidden_size)] for _ in range(input_size)]
            self.weights_hidden_output = [[random.uniform(-0.5, 0.5) for _ in range(output_size)] for _ in range(hidden_size)]
        
        self.training_iterations = 0
        self.loss_history = []
        self.val_loss_history = []
        self.best_val_loss = float('inf')
        self.patience_counter = 0
        self.early_stop_patience = 50
        self.learning_rate = 0.05
    
    def forward(self, features, training=False):
        """
        Прямой проход нейросети
        features: список из 5 чисел [rsi, atr, trend, volatility, spread]
        Возвращает: вероятности для [BUY, SELL, HOLD]
        """
        if NUMPY_AVAILABLE:
            if not isinstance(features, np.ndarray):
                features = np.array(features).reshape(1, -1)
            
            # Скрытый слой с активацией tanh
            hidden = np.dot(features, self.weights_input_hidden) + self.bias_hidden
            
            # ДОБАВЛЕНО: Batch Normalization
            if training:
                batch_mean = np.mean(hidden, axis=0, keepdims=True)
                batch_var = np.var(hidden, axis=0, keepdims=True)
                self.bn_running_mean = 0.9 * self.bn_running_mean + 0.1 * batch_mean
                self.bn_running_var = 0.9 * self.bn_running_var + 0.1 * batch_var
            else:
                batch_mean = self.bn_running_mean
                batch_var = self.bn_running_var
            
            hidden = (hidden - batch_mean) / np.sqrt(batch_var + 1e-8)
            hidden = self.bn_gamma * hidden + self.bn_beta
            hidden = np.tanh(hidden)
            
            # ДОБАВЛЕНО: Dropout (только при обучении)
            if training and self.dropout_rate > 0:
                mask = np.random.binomial(1, 1 - self.dropout_rate, size=hidden.shape) / (1 - self.dropout_rate)
                hidden = hidden * mask
            
            # Выходной слой
            output = np.dot(hidden, self.weights_hidden_output) + self.bias_output
            # Softmax для вероятностей
            probabilities = softmax(output.flatten())
            return probabilities
        else:
            # Упрощённая версия без numpy
            return [0.4, 0.3, 0.3]  # Fallback
    
    def backward(self, features, target, learning_rate=None):
        """
        Обратный проход (обучение) — градиентный спуск
        target: [1,0,0] для BUY, [0,1,0] для SELL, [0,0,1] для HOLD
        """
        if not NUMPY_AVAILABLE:
            return
        
        if learning_rate is None:
            learning_rate = self.learning_rate
        
        features = np.array(features).reshape(1, -1)
        target = np.array(target).reshape(1, -1)
        
        # Прямой проход
        hidden = np.dot(features, self.weights_input_hidden) + self.bias_hidden
        
        # Batch Normalization (обучение)
        batch_mean = np.mean(hidden, axis=0, keepdims=True)
        batch_var = np.var(hidden, axis=0, keepdims=True)
        self.bn_running_mean = 0.9 * self.bn_running_mean + 0.1 * batch_mean
        self.bn_running_var = 0.9 * self.bn_running_var + 0.1 * batch_var
        
        hidden_norm = (hidden - batch_mean) / np.sqrt(batch_var + 1e-8)
        hidden_norm = self.bn_gamma * hidden_norm + self.bn_beta
        hidden_activated = np.tanh(hidden_norm)
        
        # Dropout (при обучении)
        mask = np.random.binomial(1, 1 - self.dropout_rate, size=hidden_activated.shape) / (1 - self.dropout_rate)
        hidden_dropped = hidden_activated * mask
        
        output = np.dot(hidden_dropped, self.weights_hidden_output) + self.bias_output
        probabilities = softmax(output.flatten()).reshape(1, -1)
        
        # Ошибка (кросс-энтропия)
        loss = -np.sum(target * np.log(probabilities + 1e-8))
        self.loss_history.append(loss)
        if len(self.loss_history) > 100:
            self.loss_history = self.loss_history[-100:]
        
        # Градиенты для выходного слоя
        output_error = probabilities - target
        self.weights_hidden_output -= learning_rate * np.dot(hidden_dropped.T, output_error)
        self.bias_output -= learning_rate * np.sum(output_error, axis=0, keepdims=True)
        
        # Градиенты для скрытого слоя
        hidden_error = np.dot(output_error, self.weights_hidden_output.T)
        hidden_error = hidden_error * (1 - hidden_activated ** 2)  # Производная tanh
        
        # Градиенты для BN
        bn_error = hidden_error * self.bn_gamma
        bn_error = bn_error / np.sqrt(batch_var + 1e-8)
        
        self.weights_input_hidden -= learning_rate * np.dot(features.T, bn_error)
        self.bias_hidden -= learning_rate * np.sum(bn_error, axis=0, keepdims=True)
        
        # Обновление BN параметров
        self.bn_gamma -= learning_rate * np.sum(hidden_error * hidden_norm, axis=0, keepdims=True)
        self.bn_beta -= learning_rate * np.sum(hidden_error, axis=0, keepdims=True)
        
        self.training_iterations += 1
    
    def validate(self, val_features, val_targets):
        """ДОБАВЛЕНО: Валидация на отложенной выборке (early stopping)"""
        if not val_features or not val_targets:
            return
        
        val_losses = []
        for i in range(len(val_features)):
            probs = self.forward(val_features[i], training=False)
            target = val_targets[i]
            loss = -np.sum(target * np.log(probs + 1e-8))
            val_losses.append(loss)
        
        avg_val_loss = np.mean(val_losses) if val_losses else float('inf')
        self.val_loss_history.append(avg_val_loss)
        
        if len(self.val_loss_history) > 20:
            self.val_loss_history = self.val_loss_history[-20:]
        
        # Early stopping logic
        if avg_val_loss < self.best_val_loss - 0.01:
            self.best_val_loss = avg_val_loss
            self.patience_counter = 0
            return True  # Improvement
        else:
            self.patience_counter += 1
            if self.patience_counter >= self.early_stop_patience:
                self.learning_rate *= 0.95  # Уменьшаем learning rate при застое
                logger.info(f"🧠 Early stopping trigger: reducing LR to {self.learning_rate:.5f}")
                self.patience_counter = self.early_stop_patience // 2
            return False  # No improvement
    
    def predict_action(self, features):
        """Возвращает предсказанное действие (BUY/SELL/HOLD) и уверенность"""
        probs = self.forward(features, training=False)
        if NUMPY_AVAILABLE:
            action_idx = np.argmax(probs)
            confidence = probs[action_idx]
        else:
            action_idx = 0
            confidence = 0.5
        
        actions = ["BUY", "SELL", "HOLD"]
        return actions[action_idx], float(confidence)
    
    def get_weights(self):
        """Получить веса для сохранения"""
        if NUMPY_AVAILABLE:
            return {
                "input_hidden": self.weights_input_hidden.tolist(),
                "hidden_output": self.weights_hidden_output.tolist(),
                "bias_hidden": self.bias_hidden.tolist(),
                "bias_output": self.bias_output.tolist(),
                "bn_gamma": self.bn_gamma.tolist(),
                "bn_beta": self.bn_beta.tolist(),
                "bn_running_mean": self.bn_running_mean.tolist(),
                "bn_running_var": self.bn_running_var.tolist(),
                "training_iterations": self.training_iterations,
                "loss_history": self.loss_history[-50:],
                "best_val_loss": float(self.best_val_loss)
            }
        return None
    
    def set_weights(self, weights_data):
        """Установить веса из сохранённых данных"""
        if not NUMPY_AVAILABLE or not weights_data:
            return
        self.weights_input_hidden = np.array(weights_data["input_hidden"])
        self.weights_hidden_output = np.array(weights_data["hidden_output"])
        self.bias_hidden = np.array(weights_data["bias_hidden"])
        self.bias_output = np.array(weights_data["bias_output"])
        if "bn_gamma" in weights_data:
            self.bn_gamma = np.array(weights_data["bn_gamma"])
            self.bn_beta = np.array(weights_data["bn_beta"])
            self.bn_running_mean = np.array(weights_data["bn_running_mean"])
            self.bn_running_var = np.array(weights_data["bn_running_var"])
        self.training_iterations = weights_data.get("training_iterations", 0)
        self.loss_history = weights_data.get("loss_history", [])
        self.best_val_loss = weights_data.get("best_val_loss", float('inf'))

