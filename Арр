# ФУНКЦИЯ ПОЛУЧЕНИЯ РЕАЛЬНЫХ ДАННЫХ РЫНКА ЧЕРЕЗ MT5
# ═══════════════════════════════════════════════════════════════════════════

def get_real_market_data(symbol="XAUUSD", force_refresh=False):
    if not init_mt5():
        logger.warning("⚠️ MT5 не подключён — ИИ не видит реальных данных!")
        creds = load_mt5_session()
        if creds:
            init_mt5(creds.get("login"), creds.get("password"), creds.get("server"))
        return None
    
    try:
        tick = mt5.symbol_info_tick(symbol)
        if not tick:
            return None
        
        rates_m5 = mt5.copy_rates_from_pos(symbol, mt5.TIMEFRAME_M5, 0, 200)
        rates_h1 = mt5.copy_rates_from_pos(symbol, mt5.TIMEFRAME_H1, 0, 100)
        rates_h4 = mt5.copy_rates_from_pos(symbol, mt5.TIMEFRAME_H4, 0, 50)
        
        if rates_m5 is None:
            return None
        
        pd = get_pandas()
        df_m5 = pd.DataFrame(rates_m5)
        df_h1 = pd.DataFrame(rates_h1) if rates_h1 is not None else df_m5
        df_h4 = pd.DataFrame(rates_h4) if rates_h4 is not None else df_m5
        
        df_m5['ema20'] = df_m5['close'].ewm(span=20, adjust=False).mean()
        df_m5['ema50'] = df_m5['close'].ewm(span=50, adjust=False).mean()
        df_m5['atr'] = (df_m5['high'] - df_m5['low']).rolling(14).mean()
        
        delta = df_m5['close'].diff()
        gain = delta.where(delta > 0, 0.0).rolling(14).mean()
        loss = (-delta.where(delta < 0, 0.0)).rolling(14).mean()
        rs = gain / loss
        df_m5['rsi'] = 100.0 - (100.0 / (1.0 + rs))
        
        current_price = tick.bid
        ema20_val = float(df_m5['ema20'].iloc[-1])
        ema50_val = float(df_m5['ema50'].iloc[-1])
        
        trend_m5 = "UP" if current_price > ema20_val else "DOWN"
        trend_h1 = "UP" if float(df_h1['close'].iloc[-1]) > float(df_h1['close'].ewm(span=20, adjust=False).mean().iloc[-1]) else "DOWN" if rates_h1 is not None else trend_m5
        trend_h4 = "UP" if float(df_h4['close'].iloc[-1]) > float(df_h4['close'].ewm(span=20, adjust=False).mean().iloc[-1]) else "DOWN" if rates_h4 is not None else trend_m5
        
        return {
            "symbol": symbol,
            "bid": tick.bid,
            "ask": tick.ask,
            "spread": round(tick.ask - tick.bid, 2),
            "current_price": current_price,
            "rsi": round(float(df_m5['rsi'].iloc[-1]), 1),
            "atr": round(float(df_m5['atr'].iloc[-1]), 1),
            "ema20": round(ema20_val, 2),
            "ema50": round(ema50_val, 2),
            "trend_m5": trend_m5,
            "trend_h1": trend_h1,
            "trend_h4": trend_h4,
            "volume": int(df_m5['tick_volume'].iloc[-1]) if 'tick_volume' in df_m5 else 0,
            "high_24h": float(df_m5['high'].iloc[-288:].max()) if len(df_m5) >= 288 else float(df_m5['high'].max()),
            "low_24h": float(df_m5['low'].iloc[-288:].min()) if len(df_m5) >= 288 else float(df_m5['low'].min()),
            "timestamp": datetime.now(MSK).strftime("%H:%M:%S"),
        }
    except Exception as e:
        logger.error(f"❌ Ошибка получения реальных данных рынка: {e}")
        return None

