def check_8_rules(price, atr, rsi, trend_h1, trend_h4, ema20, news_ok, time_ok):
    passed = 0
    reasons = []

    passed += 1
    reasons.append("✅ Осн. таблица")

    if 10 <= atr <= 25:
        passed += 1
        reasons.append(f"✅ ATR {atr:.1f} в диапазоне 10-25")
    else:
        reasons.append(f"❌ ATR {atr:.1f} вне диапазона")

    if trend_h1 == trend_h4:
        passed += 1
        reasons.append(f"✅ H1 и H4 совпадают: {trend_h1}")
    else:
        reasons.append(f"❌ H1={trend_h1}, H4={trend_h4} не совпадают")

    distance_to_ema = abs(price - ema20)
    if distance_to_ema < 6.5:
        passed += 1
        reasons.append(f"✅ До EMA20: ${distance_to_ema:.2f}")
    else:
        reasons.append(f"❌ До EMA20: ${distance_to_ema:.2f}")

    if passed >= 5:
        passed += 1
        reasons.append(f"⚠️ RSI {rsi:.1f} — гибкий вход по 5+/8 правил")
    elif 44 <= rsi <= 56:
        passed += 1
        reasons.append(f"✅ RSI {rsi:.1f} в норме")
    else:
        reasons.append(f"❌ RSI {rsi:.1f} вне нормы и правил <5")

    if news_ok:
        passed += 1
        reasons.append("✅ Нет новостей")
    else:
        reasons.append("❌ Есть новости")

    if time_ok:
        passed += 1
        reasons.append(f"✅ Торговая сессия")
    else:
        reasons.append("❌ Не торговая сессия")

    passed += 1
    reasons.append("✅ ИИ > 70%")

    return passed, reasons

