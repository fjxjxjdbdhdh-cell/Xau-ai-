            {"name": "Нисходящий тренд → SELL", "description": "downtrend", "action": "SELL", "condition": "trend_down", "confidence": 0.70, "used_count": 0, "success_count": 0},
            {"name": "ATR низкая → осторожность", "description": "low_atr", "action": "HOLD", "condition": "atr_low", "confidence": 0.60, "used_count": 0, "success_count": 0},
