                    self.causal_memory = dict(list(self.causal_memory.items())[-self.MAX_MEMORY_SIZE:])
                
                self.total_decisions = state.get("total_decisions", 0)
                self.correct_decisions = state.get("correct_decisions", 0)
                self.learning_iterations = state.get("learning_iterations", 0)
                self.decision_history = state.get("decision_history", [])
                
                # Загружаем правила (но не перезаписываем полностью, только дополняем)
                saved_rules = state.get("rules", [])
                existing_names = {r.get("name") for r in self.rules}
                for rule in saved_rules:
                    if rule.get("name") not in existing_names:
                        self.rules.append(rule)
                
                # Загружаем веса нейросети
                if self.neural_net and state.get("neural_net_weights"):
                    self.neural_net.set_weights(state["neural_net_weights"])
                
                # Загружаем данные для обучения
