# ДОБАВЛЕНО: Kelly Criterion для управления капиталом
# ═══════════════════════════════════════════════════════════════════════════

def calculate_kelly_criterion(winrate, avg_win, avg_loss):
    """
    Kelly Criterion для оптимального размера позиции
    Формула: f = (p * b - q) / b
    где p = вероятность выигрыша, q = 1-p, b = avg_win/avg_loss
    """
    if avg_loss == 0:
        return 0.01
    
    b = abs(avg_win / avg_loss) if avg_loss != 0 else 1
    q = 1 - winrate
    
    if b == 0:
        return 0.01
    
    kelly = (winrate * b - q) / b
    
    # Ограничиваем и применяем дробный Kelly (25% от полного Kelly)
    kelly = max(0.005, min(0.05, kelly * 0.25))
    
    return round(kelly, 4)

def calculate_dynamic_lot(winrate, avg_win, avg_loss, current_drawdown_percent, base_lot=0.02):
    """
    Динамический расчёт лота с учётом просадки
    """
    # Базовый расчёт по Kelly
    kelly_lot = calculate_kelly_criterion(winrate, avg_win, avg_loss)
    
    # Корректируем на просадку
    if current_drawdown_percent > 0:
        drawdown_factor = max(0.3, 1 - (current_drawdown_percent / 100))
    else:
        drawdown_factor = 1.0
    
    final_lot = base_lot * kelly_lot * 20 * drawdown_factor  # kelly_lot * 20 = процент от депозита
    final_lot = max(0.005, min(0.1, final_lot))  # Ограничиваем 0.005-0.1
    
    return round(final_lot, 3)

