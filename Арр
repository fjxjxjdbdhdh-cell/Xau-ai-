            return False
        
        if not privileges.get("unlimited_trades") and self.stats.get("auto_pnl", 0) >= DAILY_PROFIT_TARGET:
            return False
        
        if not privileges.get("no_daily_loss_limit") and self.stats.get("auto_pnl", 0) <= DAILY_LOSS_LIMIT:
            return False
        
        return True

