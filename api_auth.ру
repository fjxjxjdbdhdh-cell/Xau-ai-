from flask import Blueprint, request, jsonify
from flask_jwt_extended import create_access_token, create_refresh_token, jwt_required, get_jwt_identity
from auth import register_user, login_user
from models import User

bp = Blueprint("auth", __name__, url_prefix="/api/auth")

@bp.route("/register", methods=["POST"])
def register():
    d = request.get_json() or {}
    u, p = d.get("username", "").strip(), d.get("password", "").strip()
    if not u or not p or len(u) < 3 or len(p) < 6:
        return jsonify({"error": "Логин (3+) и пароль (6+) обязательны"}), 400
    r = register_user(u, p, d.get("email"))
    if "error" in r:
        return jsonify(r), 409
    return jsonify({"access_token": create_access_token(identity=u), "refresh_token": create_refresh_token(identity=u), "user": r}), 201

@bp.route("/login", methods=["POST"])
def login():
    d = request.get_json() or {}
    u, p = d.get("username", "").strip(), d.get("password", "").strip()
    if not u or not p:
        return jsonify({"error": "Логин и пароль обязательны"}), 400
    r = login_user(u, p)
    if "error" in r:
        return jsonify(r), 401
    return jsonify({"access_token": create_access_token(identity=u), "refresh_token": create_refresh_token(identity=u), "user": r}), 200

@bp.route("/me", methods=["GET"])
@jwt_required()
def me():
    u = User.query.filter_by(username=get_jwt_identity()).first()
    if not u:
        return jsonify({"error": "Не найден"}), 404
    return jsonify({"id": u.id, "username": u.username, "tier": u.tier, "theme": u.theme}), 200
