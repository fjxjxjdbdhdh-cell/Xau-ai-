from flask import Blueprint, request, jsonify
from flask_jwt_extended import jwt_required, get_jwt_identity
from models import User, MT5Account, Trade
from extensions import db
from mt5_client import mt5_manager

bp = Blueprint("trading", __name__, url_prefix="/api/trading")

@bp.route("/accounts", methods=["GET"])
@jwt_required()
def list_acc():
    u = User.query.filter_by(username=get_jwt_identity()).first()
    if not u:
        return jsonify({"error": "Не найден"}), 404
    accs = MT5Account.query.filter_by(user_id=u.id, is_active=True).all()
    return jsonify({"accounts": [{"id": a.id, "login": a.login, "server": a.server} for a in accs]})

@bp.route("/accounts/add", methods=["POST"])
@jwt_required()
def add_acc():
    u = User.query.filter_by(username=get_jwt_identity()).first()
    if not u:
        return jsonify({"error": "Не найден"}), 404
    d = request.get_json() or {}
    login, pw, srv = d.get("login"), d.get("password"), d.get("server")
    if not all([login, pw, srv]):
        return jsonify({"error": "Все поля обязательны"}), 400
    a = MT5Account(user_id=u.id, login=login, password_encrypted=pw, server=srv, account_name=d.get("name", ""))
    db.session.add(a)
    db.session.commit()
    return jsonify({"success": True, "account_id": a.id}), 201

@bp.route("/history", methods=["GET"])
@jwt_required()
def hist():
    u = User.query.filter_by(username=get_jwt_identity()).first()
    if not u:
        return jsonify({"error": "Не найден"}), 404
    trs = Trade.query.filter_by(user_id=u.id).order_by(Trade.created_at.desc()).limit(20).all()
    return jsonify({"trades": [{"signal": t.signal, "entry": float(t.entry_price), "pnl": float(t.pnl), "status": t.status} for t in trs]})
